<?xml version='1.0' encoding='UTF-8'?>
<model name="my_model" xmlns="http://www.cellml.org/cellml/1.1#" xmlns:cellml="http://www.cellml.org/cellml/1.1#">
    <units name="millivolt">
        <unit prefix="milli" units="volt"/>
    </units>
    <units name="per_s">
        <unit exponent="-1" units="second"/>
    </units>
    <units name="per_m">
        <unit exponent="-1" units="metre"/>
    </units>
    <units name="nS">
        <!--nanoSieman-->
        <unit prefix="nano" units="siemens"/>
    </units>
    <units name="nSmV">
        <unit units="nS"/>
        <unit units="mV"/>
    </units>
    <units name="per_ms">
        <unit exponent="-1" prefix="milli" units="second"/>
    </units>
    <units name="mM_per_ms">
        <unit units="mM"/>
        <unit exponent="-1" units="ms"/>
    </units>
    <units name="mMms">
        <unit units="mM"/>
        <unit units="ms"/>
    </units>
    <units name="per_mMms">
        <unit exponent="-1" units="mMms"/>
    </units>
    <units name="mM">
        <unit prefix="milli" units="mole"/>
        <unit exponent="-1" units="litre"/>
    </units>
    <units name="micromolar">
        <unit prefix="micro" units="mole"/>
        <unit exponent="-1" units="litre"/>
    </units>
    <units name="nanomolar">
        <unit prefix="nano" units="mole"/>
        <unit exponent="-1" units="litre"/>
    </units>
    <units name="ms">
        <unit prefix="milli" units="second"/>
    </units>
    <units name="m_cubed">
        <unit exponent="3" units="metre"/>
    </units>
    <units name="mV">
        <unit prefix="milli" units="volt"/>
    </units>
    <units name="m_cubed_per_second">
        <unit units="m_cubed"/>
        <unit units="per_s"/>
    </units>
    <units name="micromolar_m_cubed">
        <unit units="micromolar"/>
        <unit units="m_cubed"/>
    </units>
    <units name="C">
        <unit units="ampere"/>
        <unit units="second"/>
    </units>
    <units name="C_per_M">
        <unit units="coulomb"/>
        <unit exponent="-1" units="mole"/>
    </units>
    <units name="J_per_MK">
        <unit units="joule"/>
        <unit exponent="-1" units="kelvin"/>
        <unit exponent="-1" units="mole"/>
    </units>
    <units name="picoA">
        <unit prefix="pico" units="ampere"/>
    </units>
    <units name="microL">
        <unit prefix="micro" units="litre"/>
    </units>
    <units name="Farad">
        <unit units="coulomb"/>
        <unit exponent="-1" units="volt"/>
    </units>
    <units name="picoFarad">
        <unit prefix="pico" units="Farad"/>
    </units>
    <units name="Js_per_m3">
        <unit units="joule"/>
        <unit units="second"/>
        <unit exponent="-3" units="metre"/>
    </units>
    <!-- Density (kg/m3)-->
    <units name="Js2_per_m5">
        <unit units="joule"/>
        <unit exponent="2" units="second"/>
        <unit exponent="-5" units="metre"/>
    </units>
    <units name="J_per_m3">
        <unit units="joule"/>
        <unit exponent="-3" units="metre"/>
    </units>
    <units name="m6_per_J">
        <unit exponent="6" units="metre"/>
        <unit exponent="-1" units="joule"/>
    </units>
    <units name="Js_per_m6">
        <unit units="joule"/>
        <unit units="second"/>
        <unit exponent="-6" units="metre"/>
    </units>
    <units name="m3_per_s">
        <unit exponent="3" units="metre"/>
        <unit exponent="-1" units="second"/>
    </units>
    <units name="mm3_per_s">
        <unit exponent="3" prefix="milli" units="metre"/>
        <unit exponent="-1" units="second"/>
    </units>
    <units name="m3">
        <unit exponent="3" units="metre"/>
    </units>
    <component name="vv_junction">
        <!--////global vairbales-->
        <variable initial_value="6550" name="u3" public_interface="out" units="J_per_m3"/>
        <variable initial_value="0" name="t" public_interface="out" units="second"/>
        <variable initial_value="0.01" name="tau_H_mean" public_interface="out" units="second"/>
        <variable initial_value="0.001" name="mu_plasma" public_interface="out" units="Js_per_m3"/>
        <variable initial_value="133" name="u_ext" public_interface="out" units="J_per_m3"/>
        <variable initial_value="1e-16" name="v_scale" public_interface="out" units="m3_per_s"/>
        <variable initial_value="1e-5" name="tau_link" public_interface="out" units="second"/>
        <variable initial_value="0.45" name="H_global_L" public_interface="out" units="dimensionless"/>
        <variable initial_value="0.6" name="H_global_R" public_interface="out" units="dimensionless"/>
        <variable initial_value="1e-30" name="v_eps" public_interface="out" units="m3_per_s"/>
        <!-- prevent 0/0-->
        <variable initial_value="1e-4" name="tau_junc" public_interface="out" units="second"/>
        <!-- lag for sampling/holding-->
        <variable initial_value="0.00009" name="l_PV1" public_interface="out" units="metre"/>
        <variable initial_value="0.000008" name="r_PV1" public_interface="out" units="metre"/>
        <variable initial_value="0.0002" name="l_VP1" public_interface="out" units="metre"/>
        <variable initial_value="0.0000077" name="r_VP1" public_interface="out" units="metre"/>
        <variable initial_value="1.99e-13" name="v_in" public_interface="out" units="m3_per_s"/>
        <variable initial_value="100" name="t0" public_interface="out" units="second"/>
        <variable initial_value="0.1" name="tau_sig" public_interface="out" units="second"/>
        <!-- transition width-->
        <variable name="u_in" public_interface="out" units="J_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="J_per_m3">6666</cn>
                        <apply>
                            <gt/>
                            <ci>t</ci>
                            <cn cellml:units="second">100</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="J_per_m3">6666</cn>
                        <apply>
                            <leq/>
                            <ci>t</ci>
                            <cn cellml:units="second">100</cn>
                        </apply>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable initial_value="6500" name="u_out1" public_interface="out" units="J_per_m3"/>
        <variable initial_value="6500" name="u_out2_init" public_interface="out" units="J_per_m3"/>
        <variable initial_value="6800" name="u_out2_final" public_interface="out" units="J_per_m3"/>
        <variable name="u_out2" public_interface="out" units="J_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_out2</ci>
                <apply>
                    <plus/>
                    <ci>u_out2_init</ci>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>u_out2_final</ci>
                            <ci>u_out2_init</ci>
                        </apply>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <minus/>
                                        <apply>
                                            <minus/>
                                            <ci>t</ci>
                                            <ci>t0</ci>
                                        </apply>
                                    </apply>
                                    <ci>tau_sig</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--///////to be commented out
var u_out_1: J_per_m3 {init: 6100, pub: out};-->
        <!--var v_out_3: m3_per_s {init: 1.98e-13, pub: out};-->
        <variable initial_value="0.0005" name="l_PP1" public_interface="out" units="metre"/>
        <variable initial_value="0.000008" name="r_PP1" public_interface="out" units="metre"/>
        <variable initial_value="0.00005" name="l_PP2" public_interface="out" units="metre"/>
        <variable initial_value="0.000004" name="r_PP2" public_interface="out" units="metre"/>
        <variable initial_value="0.00005" name="l_PP3" public_interface="out" units="metre"/>
        <variable initial_value="0.0000035" name="r_PP3" public_interface="out" units="metre"/>
        <!--///for initialization of RBC_mass_PP3,q_PP3-->
        <variable initial_value="1e-25" name="div_0" public_interface="out" units="dimensionless"/>
        <variable initial_value="1e-8" name="div_0y" public_interface="out" units="dimensionless"/>
        <!--so when intializing with no flow, hematocrit =0.45 because 0.45+Div_0/div_0-->
        <variable initial_value="0.0" name="H_ph" public_interface="out" units="dimensionless"/>
        <!--var H_L_out_VP1: dimensionless {init: 0.6, pub: out};-->
        <variable initial_value="1e-9" name="one_mm3" public_interface="out" units="m3"/>
        <!-- 1 mm^3 in m^3-->
        <!--/place holder for the blocked vessel in vv junction-->
        <variable initial_value="0.000001" name="l_VV1" public_interface="out" units="metre"/>
        <variable initial_value="0.000005" name="r_VV1" public_interface="out" units="metre"/>
        <variable initial_value="0" name="q_C_init" public_interface="out" units="m3"/>
        <variable initial_value="0.00000" name="l_VV2" public_interface="out" units="metre"/>
        <variable initial_value="0.000000" name="r_VV2" public_interface="out" units="metre"/>
        <!--/////////////////////////////PP1/////////////////////////////////////-->
        <variable name="w_v1" public_interface="out" units="dimensionless"/>
        <variable name="w_v2" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v1</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v1</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_v2</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v2</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_PP1R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_PP1R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_VP1</ci>
                        <ci>H_link_PP1R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_L_in_PP1" public_interface="out" units="dimensionless"/>
        <variable name="H_R_in_PP1" public_interface="out" units="dimensionless"/>
        <variable name="H_up_PP1" public_interface="out" units="dimensionless"/>
        <variable initial_value="H_global_L" name="H_down_PP1" public_interface="out" units="dimensionless"/>
        <variable name="H_L_out_PP1" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out_PP1" public_interface="out" units="dimensionless"/>
        <variable initial_value="0.02" name="gamma_mirror" public_interface="out" units="dimensionless"/>
        <variable name="s_v2" public_interface="out" units="dimensionless"/>
        <variable initial_value="0.00001" name="tau_H_down" public_interface="out" units="second"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v2</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v2</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v2</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_down_PP1_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_PP1_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v2</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean_PP1</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean_PP1</ci>
                                    <ci>H_up_PP1</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v2</ci>
                        </apply>
                        <ci>H_mean_PP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down_PP1</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_PP1_target</ci>
                        <ci>H_down_PP1</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_L_in_PP1</ci>
                <ci>H_global_L</ci>
            </apply>
            <!-- *** loop-broken "incoming from right" ***-->
            <apply>
                <eq/>
                <ci>H_R_in_PP1</ci>
                <ci>H_link_PP1R</ci>
            </apply>
            <apply>
                <eq/>
                <ci>H_up_PP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v2</ci>
                        <ci>H_L_in_PP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v2</ci>
                        </apply>
                        <ci>H_R_in_PP1</ci>
                    </apply>
                </apply>
            </apply>
            <!--H_down_PP1  = 2{dimensionless}*H_mean_PP1-H_up_PP1;-->
            <apply>
                <eq/>
                <ci>H_L_out_PP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v2</ci>
                        </apply>
                        <ci>H_down_PP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v2</ci>
                        <ci>H_L_in_PP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out_PP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v2</ci>
                        <ci>H_down_PP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v2</ci>
                        </apply>
                        <ci>H_R_in_PP1</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="RBC_mass_PP1_init" name="RBC_mass_PP1" public_interface="out" units="m3"/>
        <variable name="RBC_mass_PP1_init" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_mass_PP1_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us_PP1</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_PP1_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_PP1_target</ci>
                <apply>
                    <divide/>
                    <ci>RBC_mass_PP1</ci>
                    <ci>q_PP1</ci>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_mean_PP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_mean_PP1</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_PP1_target</ci>
                        <ci>H_mean_PP1</ci>
                    </apply>
                    <ci>tau_H_mean</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mass_L_PP1" public_interface="out" units="dimensionless"/>
        <variable name="H_mass_R_PP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_mass_L_PP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v1</ci>
                        <ci>H_L_in_PP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v1</ci>
                        </apply>
                        <ci>H_L_out_PP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_mass_R_PP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v2</ci>
                        <ci>H_R_out_PP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v2</ci>
                        </apply>
                        <ci>H_R_in_PP1</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--ode(RBC_mass_PP1, t) = v1*H_mass_L_PP1-v2*H_mass_R_PP1;-->
        <variable name="v1_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v1_neg" public_interface="out" units="m3_per_s"/>
        <variable name="v2_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v2_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v1_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v1</ci>
                    <ci>v1</ci>
                </apply>
            </apply>
            <!-- inflow from left (v1>0)-->
            <apply>
                <eq/>
                <ci>v1_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v1</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v1</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v1<0)-->
            <apply>
                <eq/>
                <ci>v2_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v2</ci>
                    <ci>v2</ci>
                </apply>
            </apply>
            <!-- flow from left to right (v2>0) => outflow on right-->
            <apply>
                <eq/>
                <ci>v2_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v2</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v2</ci>
                    </apply>
                </apply>
            </apply>
            <!-- inflow from right (v2<0)-->
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_mass_PP1</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v1</ci>
                        <ci>H_mass_L_PP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v2</ci>
                        <ci>H_mass_R_PP1</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!-- inflows-->
        <!-- outflows-->
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C_PP1" public_interface="out" units="m3"/>
        <variable name="q_PP1" public_interface="out" units="m3"/>
        <variable name="q_us_PP1" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us_PP1</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r_PP1</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l_PP1</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q_PP1</ci>
                <apply>
                    <plus/>
                    <ci>q_us_PP1</ci>
                    <ci>q_C_PP1</ci>
                </apply>
            </apply>
        </math>
        <variable name="C_PP1" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C_PP1</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l_PP1</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z_PP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z_PP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r_PP1</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r_PP1</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r_PP1</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45_PP1" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45_PP1</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r_PP1</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r_PP1</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_PP1" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_PP1</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel_PP1</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel_PP1" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel_PP1</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45_PP1</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean_PP1</ci>
                                        </apply>
                                        <ci>Z_PP1</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z_PP1</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r_PP1</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r_PP1</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R_PP1" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R_PP1</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu_PP1</ci>
                        <ci>l_PP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r_PP1</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="v1" public_interface="out" units="m3_per_s"/>
        <variable name="v1_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v1_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v1</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v1</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u1</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R_PP1</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="u1" public_interface="out" units="J_per_m3"/>
        <variable name="u1_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u1_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u1</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C_PP1</ci>
                        <ci>C_PP1</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C_PP1</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v1</ci>
                    <ci>v2</ci>
                </apply>
            </apply>
        </math>
        <variable name="v2" public_interface="out" units="m3_per_s"/>
        <variable name="v2_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v2_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v2</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v2</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u1</ci>
                        <ci>u2</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R_PP1</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="w_v3" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v3</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v3</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--///////////////////coupling between modules when L-R flow-->
        <variable initial_value="H_global_L" name="H_link_VP1L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_VP1L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_PP1</ci>
                        <ci>H_link_VP1L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_L_in_VP1" public_interface="out" units="dimensionless"/>
        <variable name="H_R_in_VP1" public_interface="out" units="dimensionless"/>
        <variable name="H_up_VP1" public_interface="out" units="dimensionless"/>
        <variable initial_value="H_global_L" name="H_down_VP1" public_interface="out" units="dimensionless"/>
        <variable name="H_L_out_VP1" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out_VP1" public_interface="out" units="dimensionless"/>
        <variable name="H_down_VP1_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_VP1_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v2</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean_VP1</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean_VP1</ci>
                                    <ci>H_up_VP1</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v2</ci>
                        </apply>
                        <ci>H_mean_VP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down_VP1</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_VP1_target</ci>
                        <ci>H_down_VP1</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
            <!-- *** loop-broken "incoming from left" ***-->
            <apply>
                <eq/>
                <ci>H_L_in_VP1</ci>
                <ci>H_link_VP1L</ci>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_in_VP1</ci>
                <ci>H_global_R</ci>
            </apply>
            <apply>
                <eq/>
                <ci>H_up_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v3</ci>
                        <ci>H_L_in_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v3</ci>
                        </apply>
                        <ci>H_R_in_VP1</ci>
                    </apply>
                </apply>
            </apply>
            <!--w_v3 just determines the directionality inside the vessel and therefore which L or R interface to use -->
            <!--H_down_VP1  = 2{dimensionless}*H_mean_VP1-H_up_VP1;-->
            <apply>
                <eq/>
                <ci>H_L_out_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v3</ci>
                        </apply>
                        <ci>H_down_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v3</ci>
                        <ci>H_L_in_VP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v3</ci>
                        <ci>H_down_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v3</ci>
                        </apply>
                        <ci>H_R_in_VP1</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="RBC_mass_VP1_init" name="RBC_mass_VP1" public_interface="out" units="m3"/>
        <variable name="RBC_mass_VP1_init" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_mass_VP1_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us_VP1</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_VP1_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_VP1_target</ci>
                <apply>
                    <divide/>
                    <ci>RBC_mass_VP1</ci>
                    <ci>q_VP1</ci>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_mean_VP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_mean_VP1</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_VP1_target</ci>
                        <ci>H_mean_VP1</ci>
                    </apply>
                    <ci>tau_H_mean</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mass_L_VP1" public_interface="out" units="dimensionless"/>
        <variable name="H_mass_R_VP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_mass_L_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v2</ci>
                        <ci>H_L_in_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v2</ci>
                        </apply>
                        <ci>H_L_out_VP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_mass_R_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v3</ci>
                        <ci>H_R_out_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v3</ci>
                        </apply>
                        <ci>H_R_in_VP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_mass_VP1</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v2</ci>
                        <ci>H_mass_L_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v3</ci>
                        <ci>H_mass_R_VP1</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="q_C_init" name="q_C_VP1" public_interface="out" units="m3"/>
        <variable name="q_VP1" public_interface="out" units="m3"/>
        <variable name="q_us_VP1" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us_VP1</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r_VP1</ci>
                        <cn cellml:units="dimensionless">2</cn>
