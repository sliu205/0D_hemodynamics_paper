        </math>
        <variable name="C_VP1" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C_VP1</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l_VP1</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z_VP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r_VP1</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r_VP1</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r_VP1</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45_VP1" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45_VP1</ci>
