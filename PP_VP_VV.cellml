            </apply>
        </math>
        <variable name="H_VP1_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_VP1_target</ci>
                <apply>
                    <divide/>
                    <ci>RBC_mass_VP1</ci>
