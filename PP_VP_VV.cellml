            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_mean_VP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_mean_VP1</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_VP1_target</ci>
                        <ci>H_mean_VP1</ci>
                    </apply>
                    <ci>tau_H_mean</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mass_L_VP1" public_interface="out" units="dimensionless"/>
        <variable name="H_mass_R_VP1" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_mass_L_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v2</ci>
                        <ci>H_L_in_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v2</ci>
                        </apply>
                        <ci>H_L_out_VP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_mass_R_VP1</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v3</ci>
                        <ci>H_R_out_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v3</ci>
                        </apply>
                        <ci>H_R_in_VP1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_mass_VP1</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v2</ci>
                        <ci>H_mass_L_VP1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v3</ci>
                        <ci>H_mass_R_VP1</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="q_C_init" name="q_C_VP1" public_interface="out" units="m3"/>
        <variable name="q_VP1" public_interface="out" units="m3"/>
        <variable name="q_us_VP1" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us_VP1</ci>
                <apply>
