                                <apply>
                                    <divide/>
                                    <ci>q_d</ci>
                                    <ci>q_0_2</ci>
                                </apply>
                                <ci>n_tube</ci>
                            </apply>
                        </apply>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
        </math>
    </component>
