            <apply>
                <eq/>
                <ci>q_0_2</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r_0</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="dimensionless">2</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q_p</ci>
                <apply>
                    <plus/>
                    <ci>q_C</ci>
                    <ci>q_0_2</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q_d</ci>
                <apply>
                    <plus/>
                    <ci>q_C_d</ci>
                    <ci>q_0_2</ci>
