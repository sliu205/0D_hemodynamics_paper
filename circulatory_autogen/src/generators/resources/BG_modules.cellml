                </apply>
                <apply>
                    <minus/>
                    <ci>v</ci>
                    <ci>v_out</ci>
                </apply>
            </apply>
            <!-- Nonlinear tube law
 for this 0D module, the length l must be divided by 2 in the formula for K_tube_visco, as the element is split with two pressure variables-->
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <ci>u_0</ci>
                    <apply>
                        <times/>
