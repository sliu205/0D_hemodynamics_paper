                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_C</ci>
                    <ci>q_0</ci>
                </apply>
            </apply>
            <!-- Constitutive Relations-->
            <apply>
                <eq/>
                <ci>h</ci>
                <apply>
                    <times/>
                    <ci>r_0</ci>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <ci>a_vessel</ci>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <ci>b_vessel</ci>
                                    <ci>r_0</ci>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>c_vessel</ci>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <ci>d_vessel</ci>
                                    <ci>r_0</ci>
                                </apply>
                            </apply>
                        </apply>
