            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_C</ci>
                    <ci>q_0</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>r</ci>
                <apply>
                    <root/>
                    <apply>
                        <divide/>
                        <ci>q</ci>
                        <apply>
                            <times/>
                            <pi/>
                            <ci>l</ci>
                        </apply>
                    </apply>
