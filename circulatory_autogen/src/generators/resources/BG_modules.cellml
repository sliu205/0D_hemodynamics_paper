                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u</ci>
                    </apply>
                    <apply>
                        <divide/>
