                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C_d</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v</ci>
                    <ci>v_out_sum</ci>
                </apply>
            </apply>
            <!-- Nonlinear tube law.-->
            <apply>
