                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_T</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
