            <!-- Conservation Laws-->
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>v</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <apply>
                            <minus/>
                            <apply>
                                <minus/>
                                <ci>u</ci>
                                <ci>u_d</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>R_flag</ci>
                                <ci>R</ci>
                                <ci>v</ci>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>beta_g</ci>
                            <ci>rho</ci>
                            <ci>g</ci>
                            <ci>l</ci>
                            <apply>
                                <cos/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <times/>
                                        <ci>theta</ci>
                                        <pi/>
                                    </apply>
                                    <cn cellml:units="dimensionless">180</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <ci>I</ci>
                </apply>
