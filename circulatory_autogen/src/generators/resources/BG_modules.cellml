                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
        </math>
    </component>
    <component name="vp_capillary_type">
        <variable name="t" public_interface="in" units="second"/>
        <!-- Constitutive parameters-->
        <variable name="mu" public_interface="in" units="Js_per_m3"/>
        <variable name="rho" public_interface="in" units="Js2_per_m5"/>
        <variable name="E" public_interface="in" units="J_per_m3"/>
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="h" public_interface="out" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <!-- var I: Js2_per_m6 {pub: out};-->
        <variable name="a_vessel" public_interface="in" units="dimensionless"/>
        <variable name="b_vessel" public_interface="in" units="per_m"/>
        <variable name="c_vessel" public_interface="in" units="dimensionless"/>
        <variable name="d_vessel" public_interface="in" units="per_m"/>
        <!-- State Variables-->
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="v_in" public_interface="in" units="m3_per_s"/>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
            <!-- Constitutive Relations-->
            <apply>
                <eq/>
                <ci>h</ci>
                <apply>
                    <times/>
                    <ci>r</ci>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <ci>a_vessel</ci>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <ci>b_vessel</ci>
                                    <ci>r</ci>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>c_vessel</ci>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <ci>d_vessel</ci>
                                    <ci>r</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <!--I = rho*l/(pi*sqr(r));-->
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2</cn>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r</ci>
                            <cn cellml:units="dimensionless">3</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>E</ci>
                        <ci>h</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu</ci>
                        <ci>l</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <!-- Conservation Laws-->
            <!-- ode(v, t)   = (u-u_out-v*R)/I;-->
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <ci>R</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v_in</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
        </math>
    </component>
    <!--////////////////////////////Hematocrit_directionality_modules///////////////-->
    <component name="PP_capillary_H_D">
        <!--import variables-->
        <variable name="t" public_interface="in" units="second"/>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="u_in" public_interface="in" units="J_per_m3"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <variable name="w_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_v_d</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v_d</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v_d</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v_d</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v_d</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v_d</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="RBC_volume_init" name="RBC_volume" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_volume</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v</ci>
                        <ci>H_volume_L</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v_d</ci>
                        <ci>H_volume_R</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="RBC_volume_init" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_volume_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us</ci>
                </apply>
            </apply>
        </math>
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <apply>
                <eq/>
                <ci>v_d_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v_d</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
            <!-- flow from left to right (v_d>0) => outflow on right-->
            <apply>
                <eq/>
                <ci>v_d_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v_d</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v_d</ci>
                    </apply>
                </apply>
            </apply>
            <!-- inflow from right (v_d<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <ci>RBC_volume</ci>
                    <ci>q</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu</ci>
                        <ci>l</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
        </math>
        <variable name="v_d" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_d_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v_d</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
    <component name="PP_pericyte_H_D">
        <!--import variables-->
        <variable name="tau_sig" public_interface="in" units="second"/>
        <variable name="t0" public_interface="in" units="second"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="R_constriction_base" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction_final" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R_constriction</ci>
                <apply>
                    <plus/>
                    <ci>R_constriction_base</ci>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>R_constriction_final</ci>
                            <ci>R_constriction_base</ci>
                        </apply>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <minus/>
                                        <apply>
                                            <minus/>
                                            <ci>t</ci>
                                            <ci>t0</ci>
                                        </apply>
                                    </apply>
                                    <ci>tau_sig</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="u_in" public_interface="in" units="J_per_m3"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <variable name="w_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_v_d</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v_d</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v_d</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v_d</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v_d</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v_d</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="RBC_volume_init" name="RBC_volume" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_volume</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v</ci>
                        <ci>H_volume_L</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v_d</ci>
                        <ci>H_volume_R</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="RBC_volume_init" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_volume_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us</ci>
                </apply>
            </apply>
        </math>
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <apply>
                <eq/>
                <ci>v_d_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v_d</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
            <!-- flow from left to right (v_d>0) => outflow on right-->
            <apply>
                <eq/>
                <ci>v_d_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v_d</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v_d</ci>
                    </apply>
                </apply>
            </apply>
            <!-- inflow from right (v_d<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <ci>RBC_volume</ci>
                    <ci>q</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">8</cn>
                            <ci>mu</ci>
                            <ci>l</ci>
                        </apply>
                        <apply>
                            <times/>
                            <pi/>
                            <apply>
                                <power/>
                                <ci>r</ci>
                                <cn cellml:units="dimensionless">4</cn>
                            </apply>
                        </apply>
                    </apply>
                    <ci>R_constriction</ci>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
        </math>
        <variable name="v_d" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_d_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v_d</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
    <component name="VP_capillary_H_D">
        <!--import variables-->
        <variable name="t" public_interface="in" units="second"/>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="v_in" public_interface="in" units="m3_per_s"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="RBC_volume_init" name="RBC_volume" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_volume</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v_in</ci>
                        <ci>H_volume_L</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v</ci>
                        <ci>H_volume_R</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="RBC_volume_init" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_volume_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us</ci>
                </apply>
            </apply>
        </math>
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <ci>RBC_volume</ci>
                    <ci>q</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu</ci>
                        <ci>l</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <ci>R</ci>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v_in</ci>
                    <ci>v</ci>
                </apply>
            </apply>
        </math>
    </component>
    <component name="VP_pericyte_H_D">
        <!--import variables-->
        <variable name="tau_sig" public_interface="in" units="second"/>
        <variable name="t0" public_interface="in" units="second"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="R_constriction_base" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction_final" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R_constriction</ci>
                <apply>
                    <plus/>
                    <ci>R_constriction_base</ci>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>R_constriction_final</ci>
                            <ci>R_constriction_base</ci>
                        </apply>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <minus/>
                                        <apply>
                                            <minus/>
                                            <ci>t</ci>
                                            <ci>t0</ci>
                                        </apply>
                                    </apply>
                                    <ci>tau_sig</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="v_in" public_interface="in" units="m3_per_s"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="RBC_volume_init" name="RBC_volume" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_volume</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v_in</ci>
                        <ci>H_volume_L</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v</ci>
                        <ci>H_volume_R</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="RBC_volume_init" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_volume_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us</ci>
                </apply>
            </apply>
        </math>
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <ci>RBC_volume</ci>
                    <ci>q</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">8</cn>
                            <ci>mu</ci>
                            <ci>l</ci>
                        </apply>
                        <apply>
                            <times/>
                            <pi/>
                            <apply>
                                <power/>
                                <ci>r</ci>
                                <cn cellml:units="dimensionless">4</cn>
                            </apply>
                        </apply>
                    </apply>
                    <ci>R_constriction</ci>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <ci>R</ci>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v_in</ci>
                    <ci>v</ci>
                </apply>
            </apply>
        </math>
    </component>
    <component name="VV_junction_H_D">
        <variable name="div_0" public_interface="in" units="dimensionless"/>
        <variable name="div_0y" public_interface="in" units="dimensionless"/>
        <variable name="v_threshold" public_interface="in" units="m3_per_s"/>
        <variable name="k" public_interface="in" units="dimensionless"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <!--///////////////////////vessel mapping coupling module/////////////////////-->
        <variable name="vbc1" public_interface="in" units="m3_per_s"/>
        <variable name="vbc2" public_interface="in" units="m3_per_s"/>
        <variable name="vbc3" public_interface="in" units="m3_per_s"/>
        <variable name="vbc4" public_interface="in" units="m3_per_s"/>
        <variable name="vj1" public_interface="out" units="m3_per_s"/>
        <variable name="vj2" public_interface="out" units="m3_per_s"/>
        <variable name="vj3" public_interface="out" units="m3_per_s"/>
        <variable name="vj4" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>vj1</ci>
                <ci>vbc1</ci>
            </apply>
            <apply>
                <eq/>
                <ci>vj2</ci>
                <ci>vbc2</ci>
            </apply>
            <apply>
                <eq/>
                <ci>vj3</ci>
                <apply>
                    <minus/>
                    <ci>vbc3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>vj4</ci>
                <apply>
                    <minus/>
                    <ci>vbc4</ci>
                </apply>
            </apply>
        </math>
        <!--////////////Hematocrit to port (vessel to junction) mapping////////////-->
        <variable name="H_to1" public_interface="in" units="dimensionless"/>
        <variable name="H_to2" public_interface="in" units="dimensionless"/>
        <variable name="H_to3" public_interface="in" units="dimensionless"/>
        <variable name="H_to4" public_interface="in" units="dimensionless"/>
        <!-- EXAMPLES — replace these with your actual port hematocrits:H_to1 = H_R_out_VP1;-->
        <variable name="H_split1" public_interface="out" units="dimensionless"/>
        <variable name="H_split2" public_interface="out" units="dimensionless"/>
        <variable name="H_split3" public_interface="out" units="dimensionless"/>
        <variable name="H_split4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_split1</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <!-- not a split-daughter => unchanged-->
            <apply>
                <eq/>
                <ci>H_split2</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_split3</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_split4</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="H_daughter1" public_interface="out" units="dimensionless"/>
        <variable name="H_daughter2" public_interface="out" units="dimensionless"/>
        <variable name="H_daughter3" public_interface="out" units="dimensionless"/>
        <variable name="H_daughter4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_daughter1</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split1</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_daughter2</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split2</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_daughter3</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split3</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_daughter4</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split4</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; H_from*_target: if daughter -> H_daughter*, else unchanged &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="H_from1_target" public_interface="out" units="dimensionless"/>
        <variable name="H_from2_target" public_interface="out" units="dimensionless"/>
        <variable name="H_from3_target" public_interface="out" units="dimensionless"/>
        <variable name="H_from4_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_from1_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter1</ci>
                        <apply>
                            <eq/>
                            <ci>bc1_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_from2_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter2</ci>
                        <apply>
                            <eq/>
                            <ci>bc2_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_from3_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter3</ci>
                        <apply>
                            <eq/>
                            <ci>bc3_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_from4_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter4</ci>
                        <apply>
                            <eq/>
                            <ci>bc4_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="H_from1" public_interface="out" units="dimensionless"/>
        <variable name="H_from2" public_interface="out" units="dimensionless"/>
        <variable name="H_from3" public_interface="out" units="dimensionless"/>
        <variable name="H_from4" public_interface="out" units="dimensionless"/>
        <!-- When w_out ~ 0 (not a daughter), derivative ~0 => holds last daughter value.-->
        <!--ode(H_from1, t) = w_out1*(H_from1_target-H_from1)/tau_junc;-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_from1</ci>
                <apply>
                    <times/>
                    <ci>w_out1</ci>
                    <ci>H_from1_target</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_from2</ci>
                <apply>
                    <times/>
                    <ci>w_out2</ci>
                    <ci>H_from2_target</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_from3</ci>
                <apply>
                    <times/>
                    <ci>w_out3</ci>
                    <ci>H_from3_target</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_from4</ci>
                <apply>
                    <times/>
                    <ci>w_out4</ci>
                    <ci>H_from4_target</ci>
                </apply>
            </apply>
        </math>
        <!--ode(H_from2, t) = w_out2*(H_from2_target-H_from2)/tau_junc;
ode(H_from3, t) = w_out3*(H_from3_target-H_from3)/tau_junc;
ode(H_from4, t) = w_out4*(H_from4_target-H_from4)/tau_junc;-->
        <variable name="r_bc1" public_interface="in" units="metre"/>
        <!-- diameter of vessel at port 1 (junction side)-->
        <variable name="r_bc2" public_interface="in" units="metre"/>
        <!-- diameter of vessel at port 2-->
        <variable name="r_bc3" public_interface="in" units="metre"/>
        <!-- diameter of vessel at port 3-->
        <variable name="r_bc4" public_interface="in" units="metre"/>
        <variable name="D1" public_interface="out" units="metre"/>
        <!-- diameter of vessel at port 1 (junction side)-->
        <variable name="D2" public_interface="out" units="metre"/>
        <!-- diameter of vessel at port 2-->
        <variable name="D3" public_interface="out" units="metre"/>
        <!-- diameter of vessel at port 3-->
        <variable name="D4" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D1</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc1</ci>
                </apply>
            </apply>
            <!-- <&#45;&#45; port1 attached vessel diameter (example: parent VV side)-->
            <apply>
                <eq/>
                <ci>D2</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc2</ci>
                </apply>
            </apply>
            <!-- <&#45;&#45; port2 (if unused, still define)-->
            <apply>
                <eq/>
                <ci>D3</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc3</ci>
                </apply>
            </apply>
            <!-- <&#45;&#45; port3 daughter candidate-->
            <apply>
                <eq/>
                <ci>D4</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc4</ci>
                </apply>
            </apply>
        </math>
        <variable name="w_in1" public_interface="out" units="dimensionless"/>
        <variable name="w_in2" public_interface="out" units="dimensionless"/>
        <variable name="w_in3" public_interface="out" units="dimensionless"/>
        <variable name="w_in4" public_interface="out" units="dimensionless"/>
        <!--1 when vj is positive, 0 when vj is 0-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_in1</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj1</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_in2</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj2</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_in3</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj3</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_in4</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj4</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="w_out1" public_interface="out" units="dimensionless"/>
        <variable name="w_out2" public_interface="out" units="dimensionless"/>
        <variable name="w_out3" public_interface="out" units="dimensionless"/>
        <variable name="w_out4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_out1</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in1</ci>
                </apply>
            </apply>
            <!-- ~1 if vj1<0-->
            <apply>
                <eq/>
                <ci>w_out2</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in2</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_out3</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_out4</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in4</ci>
                </apply>
            </apply>
        </math>
        <variable name="Qin1" public_interface="out" units="m3_per_s"/>
        <variable name="Qin2" public_interface="out" units="m3_per_s"/>
        <variable name="Qin3" public_interface="out" units="m3_per_s"/>
        <variable name="Qin4" public_interface="out" units="m3_per_s"/>
        <variable name="Qout1" public_interface="out" units="m3_per_s"/>
        <variable name="Qout2" public_interface="out" units="m3_per_s"/>
        <variable name="Qout3" public_interface="out" units="m3_per_s"/>
        <variable name="Qout4" public_interface="out" units="m3_per_s"/>
        <!--absolute flow into the junction-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Qin1</ci>
                <apply>
                    <times/>
                    <ci>w_in1</ci>
                    <ci>vj1</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qin2</ci>
                <apply>
                    <times/>
                    <ci>w_in2</ci>
                    <ci>vj2</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qin3</ci>
                <apply>
                    <times/>
                    <ci>w_in3</ci>
                    <ci>vj3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qin4</ci>
                <apply>
                    <times/>
                    <ci>w_in4</ci>
                    <ci>vj4</ci>
                </apply>
            </apply>
            <!--absolute (magnitude) of flow out of the junction-->
            <apply>
                <eq/>
                <ci>Qout1</ci>
                <apply>
                    <times/>
                    <ci>w_out1</ci>
                    <apply>
                        <minus/>
                        <ci>vj1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout2</ci>
                <apply>
                    <times/>
                    <ci>w_out2</ci>
                    <apply>
                        <minus/>
                        <ci>vj2</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout3</ci>
                <apply>
                    <times/>
                    <ci>w_out3</ci>
                    <apply>
                        <minus/>
                        <ci>vj3</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout4</ci>
                <apply>
                    <times/>
                    <ci>w_out4</ci>
                    <apply>
                        <minus/>
                        <ci>vj4</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="Qin_tot" public_interface="out" units="m3_per_s"/>
        <variable name="Qout_tot" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Qin_tot</ci>
                <apply>
                    <plus/>
                    <ci>Qin1</ci>
                    <ci>Qin2</ci>
                    <ci>Qin3</ci>
                    <ci>Qin4</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout_tot</ci>
                <apply>
                    <plus/>
                    <ci>Qout1</ci>
                    <ci>Qout2</ci>
                    <ci>Qout3</ci>
                    <ci>Qout4</ci>
                </apply>
            </apply>
        </math>
        <variable name="bc1_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc2_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc3_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc4_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc1_is_out" public_interface="out" units="dimensionless"/>
        <variable name="bc2_is_out" public_interface="out" units="dimensionless"/>
        <variable name="bc3_is_out" public_interface="out" units="dimensionless"/>
        <variable name="bc4_is_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>bc1_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin1</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc2_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin2</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc3_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin3</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc4_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin4</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc1_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout1</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc2_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout2</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc3_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout3</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc4_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout4</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="n_in" public_interface="out" units="dimensionless"/>
        <variable name="n_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>n_in</ci>
                <apply>
                    <plus/>
                    <ci>bc1_is_in</ci>
                    <ci>bc2_is_in</ci>
                    <ci>bc3_is_in</ci>
                    <ci>bc4_is_in</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>n_out</ci>
                <apply>
                    <plus/>
                    <ci>bc1_is_out</ci>
                    <ci>bc2_is_out</ci>
                    <ci>bc3_is_out</ci>
                    <ci>bc4_is_out</ci>
                </apply>
            </apply>
        </math>
        <!-- junction_type: +1 split (1 feeder), -1 merge (>=2 feeders), 0 other/degenerate-->
        <variable name="junction_type" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>junction_type</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <eq/>
                            <ci>n_in</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                        <apply>
                            <geq/>
                            <ci>n_in</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;- junction mode flags derived from your junction_type &#45;&#45;- -->
        <variable name="is_split" public_interface="out" units="dimensionless"/>
        <variable name="is_merge" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>is_split</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <eq/>
                            <ci>junction_type</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>is_merge</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <eq/>
                            <ci>junction_type</ci>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; pick FEED port in split: the largest Qin (ties broken 1->2->3->4) &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="feed1" public_interface="out" units="dimensionless"/>
        <variable name="feed2" public_interface="out" units="dimensionless"/>
        <variable name="feed3" public_interface="out" units="dimensionless"/>
        <variable name="feed4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>feed1</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin1</ci>
                                <ci>Qin2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin1</ci>
                                <ci>Qin3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin1</ci>
                                <ci>Qin4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>feed2</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin2</ci>
                                <ci>Qin1</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin2</ci>
                                <ci>Qin3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin2</ci>
                                <ci>Qin4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>feed3</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin3</ci>
                                <ci>Qin1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin3</ci>
                                <ci>Qin2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin3</ci>
                                <ci>Qin4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>feed4</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin4</ci>
                                <ci>Qin1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin4</ci>
                                <ci>Qin2</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin4</ci>
                                <ci>Qin3</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; alpha = daughter port with biggest Qout (ties 1->2->3->4) &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="alpha1" public_interface="out" units="dimensionless"/>
        <variable name="alpha2" public_interface="out" units="dimensionless"/>
        <variable name="alpha3" public_interface="out" units="dimensionless"/>
        <variable name="alpha4" public_interface="out" units="dimensionless"/>
        <!-- alpha1 if port1 is a daughter AND has >= Qout than others-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>alpha1</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc1_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1</ci>
                                <ci>Qout2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1</ci>
                                <ci>Qout3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1</ci>
                                <ci>Qout4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <!-- alpha2 only if not alpha1 (tie-break) and port2 is a daughter and beats remaining-->
            <apply>
                <eq/>
                <ci>alpha2</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc2_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout2</ci>
                                <ci>Qout1</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2</ci>
                                <ci>Qout3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2</ci>
                                <ci>Qout4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>alpha3</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc3_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3</ci>
                                <ci>Qout1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3</ci>
                                <ci>Qout2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout3</ci>
                                <ci>Qout4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>alpha4</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc4_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4</ci>
                                <ci>Qout1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4</ci>
                                <ci>Qout2</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4</ci>
                                <ci>Qout3</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="Qout1_rem" public_interface="out" units="m3_per_s"/>
        <variable name="Qout2_rem" public_interface="out" units="m3_per_s"/>
        <variable name="Qout3_rem" public_interface="out" units="m3_per_s"/>
        <variable name="Qout4_rem" public_interface="out" units="m3_per_s"/>
        <!-- if this port is alpha, remove it by setting to 0; else keep Qout-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Qout1_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>Qout2_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>Qout3_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>Qout4_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="beta1" public_interface="out" units="dimensionless"/>
        <variable name="beta2" public_interface="out" units="dimensionless"/>
        <variable name="beta3" public_interface="out" units="dimensionless"/>
        <variable name="beta4" public_interface="out" units="dimensionless"/>
        <!-- beta among remaining daughters (ties 1->2->3->4), must be a daughter-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>beta1</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc1_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha1</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1_rem</ci>
                                <ci>Qout2_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1_rem</ci>
                                <ci>Qout3_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1_rem</ci>
                                <ci>Qout4_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>beta2</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc2_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha2</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout2_rem</ci>
                                <ci>Qout1_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2_rem</ci>
                                <ci>Qout3_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2_rem</ci>
                                <ci>Qout4_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>beta3</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc3_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha3</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3_rem</ci>
                                <ci>Qout1_rem</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3_rem</ci>
                                <ci>Qout2_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout3_rem</ci>
                                <ci>Qout4_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>beta4</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc4_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha4</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4_rem</ci>
                                <ci>Qout1_rem</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4_rem</ci>
                                <ci>Qout2_rem</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4_rem</ci>
                                <ci>Qout3_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="D_F" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D_F</ci>
                <piecewise>
                    <piece>
                        <ci>D1</ci>
                        <apply>
                            <eq/>
                            <ci>feed1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D2</ci>
                        <apply>
                            <eq/>
                            <ci>feed2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <apply>
                            <eq/>
                            <ci>feed3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <apply>
                            <eq/>
                            <ci>feed4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; D_alpha from which ALPHA port? &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="D_alpha" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D_alpha</ci>
                <piecewise>
                    <piece>
                        <ci>D1</ci>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D2</ci>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; D_beta from which BETA port? &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="D_beta" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D_beta</ci>
                <piecewise>
                    <piece>
                        <ci>D1</ci>
                        <apply>
                            <eq/>
                            <ci>beta1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D2</ci>
                        <apply>
                            <eq/>
                            <ci>beta2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <apply>
                            <eq/>
                            <ci>beta3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <apply>
                            <eq/>
                            <ci>beta4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; daughter outflow magnitudes for alpha/beta &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="v_alpha" public_interface="out" units="m3_per_s"/>
        <variable name="v_beta" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_alpha</ci>
                <piecewise>
                    <piece>
                        <ci>Qout1</ci>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout2</ci>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout3</ci>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout4</ci>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>v_beta</ci>
                <piecewise>
                    <piece>
                        <ci>Qout1</ci>
                        <apply>
                            <eq/>
                            <ci>beta1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout2</ci>
                        <apply>
                            <eq/>
                            <ci>beta2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout3</ci>
                        <apply>
                            <eq/>
                            <ci>beta3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout4</ci>
                        <apply>
                            <eq/>
                            <ci>beta4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="FQB_alpha" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>FQB_alpha</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <ci>v_alpha</ci>
                        <ci>div_0</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>v_alpha</ci>
                        <ci>v_beta</ci>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2</cn>
                            <ci>div_0</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="FQE_alpha" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>FQE_alpha</ci>
                <apply>
                    <divide/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <minus/>
                                <apply>
                                    <plus/>
                                    <ci>A</ci>
                                    <apply>
                                        <times/>
                                        <ci>B</ci>
                                        <ci>ph</ci>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="B" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>B</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6.98</cn>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>H_mean</ci>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>D_F</ci>
                            <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="A" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>A</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">6.96</cn>
                        </apply>
                        <apply>
                            <ln/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <ci>D_alpha</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <times/>
                                    <ci>D_beta</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <ci>D_F</ci>
                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="X_0" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>X_0</ci>
                <apply>
                    <divide/>
                    <cn cellml:units="dimensionless">0.4</cn>
                    <apply>
                        <times/>
                        <ci>D_F</ci>
                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="ph" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>ph</ci>
                <apply>
                    <ln/>
                    <apply>
                        <divide/>
                        <ci>y</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>y</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="y_raw" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>y_raw</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>FQB_alpha</ci>
                        <ci>X_0</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <cn cellml:units="dimensionless">2</cn>
                                <ci>X_0</ci>
                            </apply>
                        </apply>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="y" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>y</ci>
                <apply>
                    <min/>
                    <apply>
                        <max/>
                        <ci>y_raw</ci>
                        <ci>div_0y</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>div_0y</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--var epsilon_alpha: dimensionless {pub: out};-->
        <!--epsilon_alpha = H_VV_out_alpha-H_mean*FQE_alpha/(FQB_alpha+div_0);-->
        <variable name="H_VV_out_alpha" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_VV_out_alpha</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>H_mean</ci>
                        <ci>FQE_alpha</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>FQB_alpha</ci>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--ode(H_VV_out_alpha, t) = is_split*-k*epsilon_alpha;-->
        <variable name="H_VV_out_beta" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_VV_out_beta</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>H_mean</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>FQE_alpha</ci>
                        </apply>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>FQB_alpha</ci>
                        </apply>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--////////////////////////////////VV_BG////////////////////////////////
////////////////////////////////////////////-->
        <variable name="RBC_in" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_in</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>Qin1</ci>
                        <ci>H_to1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qin2</ci>
                        <ci>H_to2</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qin3</ci>
                        <ci>H_to3</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qin4</ci>
                        <ci>H_to4</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="RBC_out" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>Qout1</ci>
                        <ci>H_from1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qout2</ci>
                        <ci>H_from2</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qout3</ci>
                        <ci>H_from3</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qout4</ci>
                        <ci>H_from4</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!-- &#45;&#45;- stored RBC volume inside VV1 &#45;&#45;- -->
        <variable name="RBC_volume_init" public_interface="out" units="m3"/>
        <variable initial_value="RBC_volume_init" name="RBC_volume" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_volume_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us</ci>
                </apply>
            </apply>
            <!-- mass balance-->
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_volume</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>RBC_in</ci>
                    <ci>RBC_out</ci>
                </apply>
            </apply>
        </math>
        <!-- &#45;&#45;- mean VV1 hematocrit (concentration) &#45;&#45;- -->
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <ci>RBC_volume</ci>
                    <apply>
                        <plus/>
                        <ci>q_us</ci>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////////setting junctional compliance to greatest compliance of the vessels connected to it -->
        <variable name="C_conn1" public_interface="in" units="m6_per_J"/>
        <variable name="C_conn2" public_interface="in" units="m6_per_J"/>
        <variable name="C_conn3" public_interface="in" units="m6_per_J"/>
        <variable name="C_conn4" public_interface="in" units="m6_per_J"/>
        <variable name="C_max12" public_interface="out" units="m6_per_J"/>
        <variable name="C_max123" public_interface="out" units="m6_per_J"/>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C_max12</ci>
                <piecewise>
                    <piece>
                        <ci>C_conn1</ci>
                        <apply>
                            <gt/>
                            <ci>C_conn1</ci>
                            <ci>C_conn2</ci>
                        </apply>
                    </piece>
                    <piece>
                        <ci>C_conn2</ci>
                        <apply>
                            <leq/>
                            <ci>C_conn1</ci>
                            <ci>C_conn2</ci>
                        </apply>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>C_max123</ci>
                <piecewise>
                    <piece>
                        <ci>C_max12</ci>
                        <apply>
                            <gt/>
                            <ci>C_max12</ci>
                            <ci>C_conn3</ci>
                        </apply>
                    </piece>
                    <piece>
                        <ci>C_conn3</ci>
                        <apply>
                            <leq/>
                            <ci>C_max12</ci>
                            <ci>C_conn3</ci>
                        </apply>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>C</ci>
                <piecewise>
                    <piece>
                        <ci>C_max123</ci>
                        <apply>
                            <gt/>
                            <ci>C_max123</ci>
                            <ci>C_conn4</ci>
                        </apply>
                    </piece>
                    <piece>
                        <ci>C_conn4</ci>
                        <apply>
                            <leq/>
                            <ci>C_max123</ci>
                            <ci>C_conn4</ci>
                        </apply>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable initial_value="q_C_init" name="q_C_d" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                    <ci>q_C_d</ci>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="in" units="Js_per_m6"/>
        <!-- State Variables-->
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
        </math>
        <variable name="u_d" public_interface="out" units="J_per_m3"/>
        <variable name="u_d_mmHg" public_interface="out" units="dimensionless"/>
        <!-- Conservation Laws
question?????????? whether ode (q_c and q_C_d) should be vbc1-4 or vj1-4-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <apply>
                            <divide/>
                            <ci>C</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <ci>vbc1</ci>
                        <ci>vbc2</ci>
                    </apply>
                    <ci>v</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_d</ci>
                    </apply>
                    <ci>R</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_d</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C_d</ci>
                        <apply>
                            <divide/>
                            <ci>C</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C_d</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                        <ci>vbc3</ci>
                    </apply>
                    <ci>vbc4</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_d_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u_d</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
    </component>
    <component name="VV_junction_H_D_I">
        <variable name="div_0" public_interface="in" units="dimensionless"/>
        <variable name="div_0y" public_interface="in" units="dimensionless"/>
        <variable name="v_threshold" public_interface="in" units="m3_per_s"/>
        <variable name="k" public_interface="in" units="dimensionless"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <!--///////////////////////vessel mapping coupling module/////////////////////-->
        <variable name="vbc1" public_interface="in" units="m3_per_s"/>
        <variable name="vbc2" public_interface="in" units="m3_per_s"/>
        <variable name="vbc3" public_interface="in" units="m3_per_s"/>
        <variable name="vbc4" public_interface="in" units="m3_per_s"/>
        <variable name="vj1" public_interface="out" units="m3_per_s"/>
        <variable name="vj2" public_interface="out" units="m3_per_s"/>
        <variable name="vj3" public_interface="out" units="m3_per_s"/>
        <variable name="vj4" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>vj1</ci>
                <ci>vbc1</ci>
            </apply>
            <apply>
                <eq/>
                <ci>vj2</ci>
                <ci>vbc2</ci>
            </apply>
            <apply>
                <eq/>
                <ci>vj3</ci>
                <apply>
                    <minus/>
                    <ci>vbc3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>vj4</ci>
                <apply>
                    <minus/>
                    <ci>vbc4</ci>
                </apply>
            </apply>
        </math>
        <!--////////////Hematocrit to port (vessel to junction) mapping////////////-->
        <variable name="H_to1" public_interface="in" units="dimensionless"/>
        <variable name="H_to2" public_interface="in" units="dimensionless"/>
        <variable name="H_to3" public_interface="in" units="dimensionless"/>
        <variable name="H_to4" public_interface="in" units="dimensionless"/>
        <!-- EXAMPLES — replace these with your actual port hematocrits:H_to1 = H_R_out_VP1;-->
        <variable name="H_split1" public_interface="out" units="dimensionless"/>
        <variable name="H_split2" public_interface="out" units="dimensionless"/>
        <variable name="H_split3" public_interface="out" units="dimensionless"/>
        <variable name="H_split4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_split1</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <!-- not a split-daughter => unchanged-->
            <apply>
                <eq/>
                <ci>H_split2</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_split3</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_split4</ci>
                <piecewise>
                    <piece>
                        <ci>H_VV_out_alpha</ci>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_VV_out_beta</ci>
                        <apply>
                            <eq/>
                            <ci>beta4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="H_daughter1" public_interface="out" units="dimensionless"/>
        <variable name="H_daughter2" public_interface="out" units="dimensionless"/>
        <variable name="H_daughter3" public_interface="out" units="dimensionless"/>
        <variable name="H_daughter4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_daughter1</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split1</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_daughter2</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split2</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_daughter3</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split3</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_daughter4</ci>
                <piecewise>
                    <piece>
                        <ci>H_mean</ci>
                        <apply>
                            <eq/>
                            <ci>is_merge</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_split4</ci>
                        <apply>
                            <eq/>
                            <ci>is_split</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; H_from*_target: if daughter -> H_daughter*, else unchanged &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="H_from1_target" public_interface="out" units="dimensionless"/>
        <variable name="H_from2_target" public_interface="out" units="dimensionless"/>
        <variable name="H_from3_target" public_interface="out" units="dimensionless"/>
        <variable name="H_from4_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_from1_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter1</ci>
                        <apply>
                            <eq/>
                            <ci>bc1_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_from2_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter2</ci>
                        <apply>
                            <eq/>
                            <ci>bc2_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_from3_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter3</ci>
                        <apply>
                            <eq/>
                            <ci>bc3_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>H_from4_target</ci>
                <piecewise>
                    <piece>
                        <ci>H_daughter4</ci>
                        <apply>
                            <eq/>
                            <ci>bc4_is_out</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>H_to4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="H_from1" public_interface="out" units="dimensionless"/>
        <variable name="H_from2" public_interface="out" units="dimensionless"/>
        <variable name="H_from3" public_interface="out" units="dimensionless"/>
        <variable name="H_from4" public_interface="out" units="dimensionless"/>
        <!-- When w_out ~ 0 (not a daughter), derivative ~0 => holds last daughter value.-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_from1</ci>
                <apply>
                    <times/>
                    <ci>w_out1</ci>
                    <ci>H_from1_target</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_from2</ci>
                <apply>
                    <times/>
                    <ci>w_out2</ci>
                    <ci>H_from2_target</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_from3</ci>
                <apply>
                    <times/>
                    <ci>w_out3</ci>
                    <ci>H_from3_target</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_from4</ci>
                <apply>
                    <times/>
                    <ci>w_out4</ci>
                    <ci>H_from4_target</ci>
                </apply>
            </apply>
        </math>
        <!--ode(H_from1, t) = w_out1*(H_from1_target-H_from1)/tau_junc;
ode(H_from2, t) = w_out2*(H_from2_target-H_from2)/tau_junc;
ode(H_from3, t) = w_out3*(H_from3_target-H_from3)/tau_junc;
ode(H_from4, t) = w_out4*(H_from4_target-H_from4)/tau_junc;-->
        <variable name="r_bc1" public_interface="in" units="metre"/>
        <!-- diameter of vessel at port 1 (junction side)-->
        <variable name="r_bc2" public_interface="in" units="metre"/>
        <!-- diameter of vessel at port 2-->
        <variable name="r_bc3" public_interface="in" units="metre"/>
        <!-- diameter of vessel at port 3-->
        <variable name="r_bc4" public_interface="in" units="metre"/>
        <variable name="D1" public_interface="out" units="metre"/>
        <!-- diameter of vessel at port 1 (junction side)-->
        <variable name="D2" public_interface="out" units="metre"/>
        <!-- diameter of vessel at port 2-->
        <variable name="D3" public_interface="out" units="metre"/>
        <!-- diameter of vessel at port 3-->
        <variable name="D4" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D1</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc1</ci>
                </apply>
            </apply>
            <!-- <&#45;&#45; port1 attached vessel diameter (example: parent VV side)-->
            <apply>
                <eq/>
                <ci>D2</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc2</ci>
                </apply>
            </apply>
            <!-- <&#45;&#45; port2 (if unused, still define)-->
            <apply>
                <eq/>
                <ci>D3</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc3</ci>
                </apply>
            </apply>
            <!-- <&#45;&#45; port3 daughter candidate-->
            <apply>
                <eq/>
                <ci>D4</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_bc4</ci>
                </apply>
            </apply>
        </math>
        <variable name="w_in1" public_interface="out" units="dimensionless"/>
        <variable name="w_in2" public_interface="out" units="dimensionless"/>
        <variable name="w_in3" public_interface="out" units="dimensionless"/>
        <variable name="w_in4" public_interface="out" units="dimensionless"/>
        <!--1 when vj is positive, 0 when vj is 0-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_in1</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj1</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_in2</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj2</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_in3</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj3</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_in4</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>vj4</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="w_out1" public_interface="out" units="dimensionless"/>
        <variable name="w_out2" public_interface="out" units="dimensionless"/>
        <variable name="w_out3" public_interface="out" units="dimensionless"/>
        <variable name="w_out4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_out1</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in1</ci>
                </apply>
            </apply>
            <!-- ~1 if vj1<0-->
            <apply>
                <eq/>
                <ci>w_out2</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in2</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_out3</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_out4</ci>
                <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>w_in4</ci>
                </apply>
            </apply>
        </math>
        <variable name="Qin1" public_interface="out" units="m3_per_s"/>
        <variable name="Qin2" public_interface="out" units="m3_per_s"/>
        <variable name="Qin3" public_interface="out" units="m3_per_s"/>
        <variable name="Qin4" public_interface="out" units="m3_per_s"/>
        <variable name="Qout1" public_interface="out" units="m3_per_s"/>
        <variable name="Qout2" public_interface="out" units="m3_per_s"/>
        <variable name="Qout3" public_interface="out" units="m3_per_s"/>
        <variable name="Qout4" public_interface="out" units="m3_per_s"/>
        <!--absolute flow into the junction-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Qin1</ci>
                <apply>
                    <times/>
                    <ci>w_in1</ci>
                    <ci>vj1</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qin2</ci>
                <apply>
                    <times/>
                    <ci>w_in2</ci>
                    <ci>vj2</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qin3</ci>
                <apply>
                    <times/>
                    <ci>w_in3</ci>
                    <ci>vj3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qin4</ci>
                <apply>
                    <times/>
                    <ci>w_in4</ci>
                    <ci>vj4</ci>
                </apply>
            </apply>
            <!--absolute (magnitude) of flow out of the junction-->
            <apply>
                <eq/>
                <ci>Qout1</ci>
                <apply>
                    <times/>
                    <ci>w_out1</ci>
                    <apply>
                        <minus/>
                        <ci>vj1</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout2</ci>
                <apply>
                    <times/>
                    <ci>w_out2</ci>
                    <apply>
                        <minus/>
                        <ci>vj2</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout3</ci>
                <apply>
                    <times/>
                    <ci>w_out3</ci>
                    <apply>
                        <minus/>
                        <ci>vj3</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout4</ci>
                <apply>
                    <times/>
                    <ci>w_out4</ci>
                    <apply>
                        <minus/>
                        <ci>vj4</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="Qin_tot" public_interface="out" units="m3_per_s"/>
        <variable name="Qout_tot" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Qin_tot</ci>
                <apply>
                    <plus/>
                    <ci>Qin1</ci>
                    <ci>Qin2</ci>
                    <ci>Qin3</ci>
                    <ci>Qin4</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>Qout_tot</ci>
                <apply>
                    <plus/>
                    <ci>Qout1</ci>
                    <ci>Qout2</ci>
                    <ci>Qout3</ci>
                    <ci>Qout4</ci>
                </apply>
            </apply>
        </math>
        <variable name="bc1_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc2_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc3_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc4_is_in" public_interface="out" units="dimensionless"/>
        <variable name="bc1_is_out" public_interface="out" units="dimensionless"/>
        <variable name="bc2_is_out" public_interface="out" units="dimensionless"/>
        <variable name="bc3_is_out" public_interface="out" units="dimensionless"/>
        <variable name="bc4_is_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>bc1_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin1</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc2_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin2</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc3_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin3</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc4_is_in</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qin4</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc1_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout1</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc2_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout2</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc3_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout3</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>bc4_is_out</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <gt/>
                            <ci>Qout4</ci>
                            <ci>v_threshold</ci>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="n_in" public_interface="out" units="dimensionless"/>
        <variable name="n_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>n_in</ci>
                <apply>
                    <plus/>
                    <ci>bc1_is_in</ci>
                    <ci>bc2_is_in</ci>
                    <ci>bc3_is_in</ci>
                    <ci>bc4_is_in</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>n_out</ci>
                <apply>
                    <plus/>
                    <ci>bc1_is_out</ci>
                    <ci>bc2_is_out</ci>
                    <ci>bc3_is_out</ci>
                    <ci>bc4_is_out</ci>
                </apply>
            </apply>
        </math>
        <!-- junction_type: +1 split (1 feeder), -1 merge (>=2 feeders), 0 other/degenerate-->
        <variable name="junction_type" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>junction_type</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <eq/>
                            <ci>n_in</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                        <apply>
                            <geq/>
                            <ci>n_in</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;- junction mode flags derived from your junction_type &#45;&#45;- -->
        <variable name="is_split" public_interface="out" units="dimensionless"/>
        <variable name="is_merge" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>is_split</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <eq/>
                            <ci>junction_type</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>is_merge</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <eq/>
                            <ci>junction_type</ci>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; pick FEED port in split: the largest Qin (ties broken 1->2->3->4) &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="feed1" public_interface="out" units="dimensionless"/>
        <variable name="feed2" public_interface="out" units="dimensionless"/>
        <variable name="feed3" public_interface="out" units="dimensionless"/>
        <variable name="feed4" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>feed1</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin1</ci>
                                <ci>Qin2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin1</ci>
                                <ci>Qin3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin1</ci>
                                <ci>Qin4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>feed2</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin2</ci>
                                <ci>Qin1</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin2</ci>
                                <ci>Qin3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin2</ci>
                                <ci>Qin4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>feed3</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin3</ci>
                                <ci>Qin1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin3</ci>
                                <ci>Qin2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qin3</ci>
                                <ci>Qin4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>feed4</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin4</ci>
                                <ci>Qin1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin4</ci>
                                <ci>Qin2</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qin4</ci>
                                <ci>Qin3</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; alpha = daughter port with biggest Qout (ties 1->2->3->4) &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="alpha1" public_interface="out" units="dimensionless"/>
        <variable name="alpha2" public_interface="out" units="dimensionless"/>
        <variable name="alpha3" public_interface="out" units="dimensionless"/>
        <variable name="alpha4" public_interface="out" units="dimensionless"/>
        <!-- alpha1 if port1 is a daughter AND has >= Qout than others-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>alpha1</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc1_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1</ci>
                                <ci>Qout2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1</ci>
                                <ci>Qout3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1</ci>
                                <ci>Qout4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <!-- alpha2 only if not alpha1 (tie-break) and port2 is a daughter and beats remaining-->
            <apply>
                <eq/>
                <ci>alpha2</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc2_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout2</ci>
                                <ci>Qout1</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2</ci>
                                <ci>Qout3</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2</ci>
                                <ci>Qout4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>alpha3</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc3_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3</ci>
                                <ci>Qout1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3</ci>
                                <ci>Qout2</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout3</ci>
                                <ci>Qout4</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>alpha4</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc4_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4</ci>
                                <ci>Qout1</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4</ci>
                                <ci>Qout2</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4</ci>
                                <ci>Qout3</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="Qout1_rem" public_interface="out" units="m3_per_s"/>
        <variable name="Qout2_rem" public_interface="out" units="m3_per_s"/>
        <variable name="Qout3_rem" public_interface="out" units="m3_per_s"/>
        <variable name="Qout4_rem" public_interface="out" units="m3_per_s"/>
        <!-- if this port is alpha, remove it by setting to 0; else keep Qout-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Qout1_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>Qout2_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout2</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>Qout3_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>Qout4_rem</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="beta1" public_interface="out" units="dimensionless"/>
        <variable name="beta2" public_interface="out" units="dimensionless"/>
        <variable name="beta3" public_interface="out" units="dimensionless"/>
        <variable name="beta4" public_interface="out" units="dimensionless"/>
        <!-- beta among remaining daughters (ties 1->2->3->4), must be a daughter-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>beta1</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc1_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha1</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1_rem</ci>
                                <ci>Qout2_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1_rem</ci>
                                <ci>Qout3_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout1_rem</ci>
                                <ci>Qout4_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>beta2</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc2_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha2</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout2_rem</ci>
                                <ci>Qout1_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2_rem</ci>
                                <ci>Qout3_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout2_rem</ci>
                                <ci>Qout4_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>beta3</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc3_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha3</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3_rem</ci>
                                <ci>Qout1_rem</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout3_rem</ci>
                                <ci>Qout2_rem</ci>
                            </apply>
                            <apply>
                                <geq/>
                                <ci>Qout3_rem</ci>
                                <ci>Qout4_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>beta4</ci>
                <piecewise>
                    <piece>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <and/>
                            <apply>
                                <eq/>
                                <ci>is_split</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>bc4_is_out</ci>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <eq/>
                                <ci>alpha4</ci>
                                <cn cellml:units="dimensionless">0</cn>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4_rem</ci>
                                <ci>Qout1_rem</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4_rem</ci>
                                <ci>Qout2_rem</ci>
                            </apply>
                            <apply>
                                <gt/>
                                <ci>Qout4_rem</ci>
                                <ci>Qout3_rem</ci>
                            </apply>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="dimensionless">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="D_F" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D_F</ci>
                <piecewise>
                    <piece>
                        <ci>D1</ci>
                        <apply>
                            <eq/>
                            <ci>feed1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D2</ci>
                        <apply>
                            <eq/>
                            <ci>feed2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <apply>
                            <eq/>
                            <ci>feed3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <apply>
                            <eq/>
                            <ci>feed4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D1</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; D_alpha from which ALPHA port? &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="D_alpha" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D_alpha</ci>
                <piecewise>
                    <piece>
                        <ci>D1</ci>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D2</ci>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; D_beta from which BETA port? &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="D_beta" public_interface="out" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D_beta</ci>
                <piecewise>
                    <piece>
                        <ci>D1</ci>
                        <apply>
                            <eq/>
                            <ci>beta1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D2</ci>
                        <apply>
                            <eq/>
                            <ci>beta2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D3</ci>
                        <apply>
                            <eq/>
                            <ci>beta3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <apply>
                            <eq/>
                            <ci>beta4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>D4</ci>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <!-- &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45; daughter outflow magnitudes for alpha/beta &#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;&#45;-->
        <variable name="v_alpha" public_interface="out" units="m3_per_s"/>
        <variable name="v_beta" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_alpha</ci>
                <piecewise>
                    <piece>
                        <ci>Qout1</ci>
                        <apply>
                            <eq/>
                            <ci>alpha1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout2</ci>
                        <apply>
                            <eq/>
                            <ci>alpha2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout3</ci>
                        <apply>
                            <eq/>
                            <ci>alpha3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout4</ci>
                        <apply>
                            <eq/>
                            <ci>alpha4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>v_beta</ci>
                <piecewise>
                    <piece>
                        <ci>Qout1</ci>
                        <apply>
                            <eq/>
                            <ci>beta1</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout2</ci>
                        <apply>
                            <eq/>
                            <ci>beta2</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout3</ci>
                        <apply>
                            <eq/>
                            <ci>beta3</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <ci>Qout4</ci>
                        <apply>
                            <eq/>
                            <ci>beta4</ci>
                            <cn cellml:units="dimensionless">1</cn>
                        </apply>
                    </piece>
                    <piece>
                        <cn cellml:units="m3_per_s">0</cn>
                        <true/>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable name="FQB_alpha" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>FQB_alpha</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <ci>v_alpha</ci>
                        <ci>div_0</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>v_alpha</ci>
                        <ci>v_beta</ci>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2</cn>
                            <ci>div_0</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="FQE_alpha" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>FQE_alpha</ci>
                <apply>
                    <divide/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <minus/>
                                <apply>
                                    <plus/>
                                    <ci>A</ci>
                                    <apply>
                                        <times/>
                                        <ci>B</ci>
                                        <ci>ph</ci>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="B" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>B</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6.98</cn>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>H_mean</ci>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>D_F</ci>
                            <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="A" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>A</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">6.96</cn>
                        </apply>
                        <apply>
                            <ln/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <ci>D_alpha</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <times/>
                                    <ci>D_beta</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <ci>D_F</ci>
                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="X_0" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>X_0</ci>
                <apply>
                    <divide/>
                    <cn cellml:units="dimensionless">0.4</cn>
                    <apply>
                        <times/>
                        <ci>D_F</ci>
                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="ph" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>ph</ci>
                <apply>
                    <ln/>
                    <apply>
                        <divide/>
                        <ci>y</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>y</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="y_raw" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>y_raw</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>FQB_alpha</ci>
                        <ci>X_0</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <cn cellml:units="dimensionless">2</cn>
                                <ci>X_0</ci>
                            </apply>
                        </apply>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="y" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>y</ci>
                <apply>
                    <min/>
                    <apply>
                        <max/>
                        <ci>y_raw</ci>
                        <ci>div_0y</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>div_0y</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--var epsilon_alpha: dimensionless {pub: out};-->
        <!--epsilon_alpha = H_VV_out_alpha-H_mean*FQE_alpha/(FQB_alpha+div_0);-->
        <variable name="H_VV_out_alpha" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_VV_out_alpha</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>H_mean</ci>
                        <ci>FQE_alpha</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>FQB_alpha</ci>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_VV_out_beta" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_VV_out_beta</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <ci>H_mean</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>FQE_alpha</ci>
                        </apply>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>FQB_alpha</ci>
                        </apply>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--////////////////////////////////VV_BG////////////////////////////////
////////////////////////////////////////////-->
        <variable name="RBC_in" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_in</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>Qin1</ci>
                        <ci>H_to1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qin2</ci>
                        <ci>H_to2</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qin3</ci>
                        <ci>H_to3</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qin4</ci>
                        <ci>H_to4</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="RBC_out" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>Qout1</ci>
                        <ci>H_from1</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qout2</ci>
                        <ci>H_from2</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qout3</ci>
                        <ci>H_from3</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>Qout4</ci>
                        <ci>H_from4</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!-- &#45;&#45;- stored RBC volume inside VV1 &#45;&#45;- -->
        <variable name="RBC_volume_init" public_interface="out" units="m3"/>
        <variable initial_value="RBC_volume_init" name="RBC_volume" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_volume_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us</ci>
                </apply>
            </apply>
            <!-- mass balance-->
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_volume</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>RBC_in</ci>
                    <ci>RBC_out</ci>
                </apply>
            </apply>
        </math>
        <!-- &#45;&#45;- mean VV1 hematocrit (concentration) &#45;&#45;- -->
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <ci>RBC_volume</ci>
                    <apply>
                        <plus/>
                        <ci>q_us</ci>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////////setting junctional compliance to greatest compliance of the vessels connected to it -->
        <variable name="C_conn1" public_interface="in" units="m6_per_J"/>
        <variable name="C_conn2" public_interface="in" units="m6_per_J"/>
        <variable name="C_conn3" public_interface="in" units="m6_per_J"/>
        <variable name="C_conn4" public_interface="in" units="m6_per_J"/>
        <variable name="C_max12" public_interface="out" units="m6_per_J"/>
        <variable name="C_max123" public_interface="out" units="m6_per_J"/>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C_max12</ci>
                <piecewise>
                    <piece>
                        <ci>C_conn1</ci>
                        <apply>
                            <gt/>
                            <ci>C_conn1</ci>
                            <ci>C_conn2</ci>
                        </apply>
                    </piece>
                    <piece>
                        <ci>C_conn2</ci>
                        <apply>
                            <leq/>
                            <ci>C_conn1</ci>
                            <ci>C_conn2</ci>
                        </apply>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>C_max123</ci>
                <piecewise>
                    <piece>
                        <ci>C_max12</ci>
                        <apply>
                            <gt/>
                            <ci>C_max12</ci>
                            <ci>C_conn3</ci>
                        </apply>
                    </piece>
                    <piece>
                        <ci>C_conn3</ci>
                        <apply>
                            <leq/>
                            <ci>C_max12</ci>
                            <ci>C_conn3</ci>
                        </apply>
                    </piece>
                </piecewise>
            </apply>
            <apply>
                <eq/>
                <ci>C</ci>
                <piecewise>
                    <piece>
                        <ci>C_max123</ci>
                        <apply>
                            <gt/>
                            <ci>C_max123</ci>
                            <ci>C_conn4</ci>
                        </apply>
                    </piece>
                    <piece>
                        <ci>C_conn4</ci>
                        <apply>
                            <leq/>
                            <ci>C_max123</ci>
                            <ci>C_conn4</ci>
                        </apply>
                    </piece>
                </piecewise>
            </apply>
        </math>
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable initial_value="q_C_init" name="q_C_d" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                    <ci>q_C_d</ci>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="in" units="Js_per_m6"/>
        <!-- State Variables-->
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
        </math>
        <variable name="u_d" public_interface="out" units="J_per_m3"/>
        <variable name="u_d_mmHg" public_interface="out" units="dimensionless"/>
        <!-- Conservation Laws
question?????????? whether ode (q_c and q_C_d) should be vbc1-4 or vj1-4-->
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <apply>
                            <divide/>
                            <ci>C</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <ci>vbc1</ci>
                        <ci>vbc2</ci>
                    </apply>
                    <ci>v</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_d</ci>
                    </apply>
                    <ci>R</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_d</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C_d</ci>
                        <apply>
                            <divide/>
                            <ci>C</ci>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C_d</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                        <ci>vbc3</ci>
                    </apply>
                    <ci>vbc4</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_d_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u_d</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
    </component>
    <component name="PP_capillary_H_D_I">
        <!--import variables-->
        <variable name="t" public_interface="in" units="second"/>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="u_in" public_interface="in" units="J_per_m3"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <variable name="w_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_v_d</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v_d</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v_d</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v_d</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v_d</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v_d</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--var RBC_volume: m3 {pub: out};-->
        <!--RBC_volume = (v*H_volume_L-v_d*H_volume_R)/(v+v_d);-->
        <!--var RBC_volume_init: m3 {pub: out};-->
        <!--RBC_volume_init = H_global_L*q_us;-->
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <apply>
                <eq/>
                <ci>v_d_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v_d</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
            <!-- flow from left to right (v_d>0) => outflow on right-->
            <apply>
                <eq/>
                <ci>v_d_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v_d</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v_d</ci>
                    </apply>
                </apply>
            </apply>
            <!-- inflow from right (v_d<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <apply>
                                <times/>
                                <ci>v</ci>
                                <ci>H_volume_L</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>v_d</ci>
                                <ci>H_volume_R</ci>
                            </apply>
                        </apply>
                        <ci>v_scale</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>v</ci>
                        <ci>v_d</ci>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2</cn>
                            <ci>v_scale</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu</ci>
                        <ci>l</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
        </math>
        <variable name="v_d" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_d_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v_d</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
    <component name="PP_pericyte_H_D_I">
        <!--import variables-->
        <variable name="tau_sig" public_interface="in" units="second"/>
        <variable name="t0" public_interface="in" units="second"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="R_constriction_base" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction_final" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R_constriction</ci>
                <apply>
                    <plus/>
                    <ci>R_constriction_base</ci>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>R_constriction_final</ci>
                            <ci>R_constriction_base</ci>
                        </apply>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <minus/>
                                        <apply>
                                            <minus/>
                                            <ci>t</ci>
                                            <ci>t0</ci>
                                        </apply>
                                    </apply>
                                    <ci>tau_sig</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="u_in" public_interface="in" units="J_per_m3"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <variable name="w_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_v_d</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v_d</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v_d</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v_d</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v_d</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v_d</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--var RBC_volume: m3 {pub: out};-->
        <!--RBC_volume = (v*H_volume_L-v_d*H_volume_R)/(v+v_d);-->
        <!--var RBC_volume_init: m3 {pub: out};-->
        <!--RBC_volume_init = H_global_L*q_us;-->
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <apply>
                <eq/>
                <ci>v_d_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v_d</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
            <!-- flow from left to right (v_d>0) => outflow on right-->
            <apply>
                <eq/>
                <ci>v_d_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v_d</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v_d</ci>
                    </apply>
                </apply>
            </apply>
            <!-- inflow from right (v_d<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <apply>
                                <times/>
                                <ci>v</ci>
                                <ci>H_volume_L</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>v_d</ci>
                                <ci>H_volume_R</ci>
                            </apply>
                        </apply>
                        <ci>v_scale</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>v</ci>
                        <ci>v_d</ci>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2</cn>
                            <ci>v_scale</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">8</cn>
                            <ci>mu</ci>
                            <ci>l</ci>
                        </apply>
                        <apply>
                            <times/>
                            <pi/>
                            <apply>
                                <power/>
                                <ci>r</ci>
                                <cn cellml:units="dimensionless">4</cn>
                            </apply>
                        </apply>
                    </apply>
                    <ci>R_constriction</ci>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
        </math>
        <variable name="v_d" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_d_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v_d</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
    <component name="VP_capillary_H_D_I">
        <!--import variables-->
        <variable name="t" public_interface="in" units="second"/>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="v_in" public_interface="in" units="m3_per_s"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--var RBC_volume: m3 {pub: out};-->
        <!--RBC_volume = (v_in*H_volume_L-v*H_volume_R)/(v_in+v);-->
        <!--var RBC_volume_init: m3 {pub: out};-->
        <!--RBC_volume_init = H_global_L*q_us;-->
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <apply>
                                <times/>
                                <ci>v_in</ci>
                                <ci>H_volume_L</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>v</ci>
                                <ci>H_volume_R</ci>
                            </apply>
                        </apply>
                        <ci>v_scale</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>v_in</ci>
                        <ci>v</ci>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2</cn>
                            <ci>v_scale</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu</ci>
                        <ci>l</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <ci>R</ci>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v_in</ci>
                    <ci>v</ci>
                </apply>
            </apply>
        </math>
    </component>
    <component name="VP_pericyte_H_D_I">
        <!--import variables-->
        <variable name="tau_sig" public_interface="in" units="second"/>
        <variable name="t0" public_interface="in" units="second"/>
        <variable name="t" public_interface="in" units="second"/>
        <variable name="R_constriction_base" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction_final" public_interface="in" units="Js_per_m6"/>
        <variable name="R_constriction" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R_constriction</ci>
                <apply>
                    <plus/>
                    <ci>R_constriction_base</ci>
                    <apply>
                        <divide/>
                        <apply>
                            <minus/>
                            <ci>R_constriction_final</ci>
                            <ci>R_constriction_base</ci>
                        </apply>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <divide/>
                                    <apply>
                                        <minus/>
                                        <apply>
                                            <minus/>
                                            <ci>t</ci>
                                            <ci>t0</ci>
                                        </apply>
                                    </apply>
                                    <ci>tau_sig</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHS" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHS" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="v_in" public_interface="in" units="m3_per_s"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHS</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHS</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHS means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--var RBC_volume: m3 {pub: out};-->
        <!--RBC_volume = (v_in*H_volume_L-v*H_volume_R)/(v_in+v);-->
        <!--var RBC_volume_init: m3 {pub: out};-->
        <!--RBC_volume_init = H_global_L*q_us;-->
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <!--var H_target: dimensionless {pub: out};-->
            <!--H_target = RBC_volume/q;-->
            <apply>
                <eq/>
                <ci>H_mean</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <apply>
                                <times/>
                                <ci>v_in</ci>
                                <ci>H_volume_L</ci>
                            </apply>
                            <apply>
                                <times/>
                                <ci>v</ci>
                                <ci>H_volume_R</ci>
                            </apply>
                        </apply>
                        <ci>v_scale</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>v_in</ci>
                        <ci>v</ci>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2</cn>
                            <ci>v_scale</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="H_mean" public_interface="out" units="dimensionless"/>
        <!--ode(H_mean, t) = (H_target-H_mean)/tau_H_mean;-->
        <variable name="H_volume_L" public_interface="out" units="dimensionless"/>
        <variable name="H_volume_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_volume_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_volume_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
