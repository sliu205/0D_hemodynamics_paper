                                <apply>
                                    <divide/>
                                    <ci>q_p</ci>
                                    <ci>q_0_2</ci>
                                </apply>
                                <ci>n_tube</ci>
                            </apply>
                        </apply>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_d</ci>
                <apply>
                    <plus/>
                    <ci>u_0</ci>
                    <apply>
                        <times/>
                        <ci>K_tube</ci>
