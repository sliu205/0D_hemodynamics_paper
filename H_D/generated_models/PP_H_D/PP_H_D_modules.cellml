</import>
    <component name="zero_flow">
        <variable name="v_zero" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_zero</ci>
                <cn cellml:units="m3_per_s">0</cn>
            </apply>
        </math>
    </component>
    <component name="PP_capillary_H_D">
        <!--import variables-->
        <variable name="t" public_interface="in" units="second"/>
        <variable name="H_global_L" public_interface="in" units="dimensionless"/>
        <variable name="H_global_R" public_interface="in" units="dimensionless"/>
        <variable name="H_L_out_RHSV" public_interface="in" units="dimensionless"/>
        <variable name="H_R_out_LHSV" public_interface="in" units="dimensionless"/>
        <variable name="gamma_mirror" public_interface="in" units="dimensionless"/>
        <variable name="tau_H_down" public_interface="in" units="second"/>
        <variable name="tau_H_mean" public_interface="in" units="second"/>
        <!--0.001-->
        <variable name="v_eps" public_interface="in" units="m3_per_s"/>
        <variable name="q_C_init" public_interface="in" units="m3"/>
        <!--0-->
        <variable name="l" public_interface="in" units="metre"/>
        <variable name="r" public_interface="in" units="metre"/>
        <variable name="mu_plasma" public_interface="in" units="Js_per_m3"/>
        <variable name="u_in" public_interface="in" units="J_per_m3"/>
        <variable name="u_ext" public_interface="in" units="J_per_m3"/>
        <variable name="u_out" public_interface="in" units="J_per_m3"/>
        <variable name="tau_link" public_interface="in" units="second"/>
        <variable name="v_scale" public_interface="in" units="m3_per_s"/>
        <variable name="one_mm3" public_interface="in" units="m3"/>
        <variable name="w_v" public_interface="out" units="dimensionless"/>
        <variable name="w_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>w_v</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>w_v_d</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">0.5</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <cn cellml:units="dimensionless">1</cn>
                            <pi/>
                        </apply>
                        <apply>
                            <arctan/>
                            <apply>
                                <divide/>
                                <ci>v_d</ci>
                                <ci>v_scale</ci>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/////////////////////////coupling with RHS vessel using ode to break 
instaneous coupling requirement/////////-->
        <variable initial_value="H_global_L" name="H_link_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_R</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_L_out_RHSV</ci>
                        <ci>H_link_R</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHSV means RHS vessel-->
        <variable initial_value="H_global_L" name="H_link_L" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_link_L</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_R_out_LHSV</ci>
                        <ci>H_link_L</ci>
                    </apply>
                    <ci>tau_link</ci>
                </apply>
            </apply>
        </math>
        <!--RHSV means RHS vessel-->
        <variable name="H_L_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_in</ci>
                <ci>H_link_L</ci>
            </apply>
        </math>
        <variable name="H_R_in" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_R_in</ci>
                <ci>H_link_R</ci>
            </apply>
        </math>
        <variable name="H_up" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_up</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_down" public_interface="out" units="dimensionless"/>
        <variable name="H_down_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_down_target</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>s_v_d</ci>
                        <apply>
                            <plus/>
                            <ci>H_mean</ci>
                            <apply>
                                <times/>
                                <ci>gamma_mirror</ci>
                                <apply>
                                    <minus/>
                                    <ci>H_mean</ci>
                                    <ci>H_up</ci>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>s_v_d</ci>
                        </apply>
                        <ci>H_mean</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_down</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_down_target</ci>
                        <ci>H_down</ci>
                    </apply>
                    <ci>tau_H_down</ci>
                </apply>
            </apply>
        </math>
        <variable name="s_v_d" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>s_v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <abs/>
                        <ci>v_d</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <abs/>
                            <ci>v_d</ci>
                        </apply>
                        <ci>v_eps</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--/useful when flow =0, if 0, make H_down=H_mean-->
        <variable name="H_L_out" public_interface="out" units="dimensionless"/>
        <variable name="H_R_out" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_L_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_L_in</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_R_out</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_down</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable initial_value="RBC_volume_init" name="RBC_volume" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_volume</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v</ci>
                        <ci>H_mass_L</ci>
                    </apply>
                    <apply>
                        <times/>
                        <ci>v_d</ci>
                        <ci>H_mass_R</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="RBC_volume_init" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>RBC_volume_init</ci>
                <apply>
                    <times/>
                    <ci>H_global_L</ci>
                    <ci>q_us</ci>
                </apply>
            </apply>
        </math>
        <!--pos/neg for RBC mass conservation only-->
        <variable name="v_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_neg" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_pos" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_neg" public_interface="out" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v</ci>
                    <ci>v</ci>
                </apply>
            </apply>
            <!-- inflow from left (v>0)-->
            <apply>
                <eq/>
                <ci>v_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v</ci>
                    </apply>
                </apply>
            </apply>
            <!-- outflow to left (v<0)-->
            <apply>
                <eq/>
                <ci>v_d_pos</ci>
                <apply>
                    <times/>
                    <ci>w_v_d</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
            <!-- flow from left to right (v_d>0) => outflow on right-->
            <apply>
                <eq/>
                <ci>v_d_neg</ci>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>w_v_d</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <ci>v_d</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!-- inflow from right (v_d<0)-->
        <variable name="H_target" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_target</ci>
                <apply>
                    <divide/>
                    <ci>RBC_volume</ci>
                    <ci>q</ci>
                </apply>
            </apply>
        </math>
        <variable initial_value="H_global_L" name="H_mean" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_mean</ci>
                </apply>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>H_target</ci>
                        <ci>H_mean</ci>
                    </apply>
                    <ci>tau_H_mean</ci>
                </apply>
            </apply>
        </math>
        <variable name="H_mass_L" public_interface="out" units="dimensionless"/>
        <variable name="H_mass_R" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>H_mass_L</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v</ci>
                        <ci>H_L_in</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v</ci>
                        </apply>
                        <ci>H_L_out</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_mass_R</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <ci>w_v_d</ci>
                        <ci>H_R_out</ci>
                    </apply>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>w_v_d</ci>
                        </apply>
                        <ci>H_R_in</ci>
                    </apply>
                </apply>
            </apply>
        </math>
        <!--//////////////-->
        <variable initial_value="q_C_init" name="q_C" public_interface="out" units="m3"/>
        <variable name="q" public_interface="out" units="m3"/>
        <variable name="q_us" public_interface="out" units="m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>q</ci>
                <apply>
                    <plus/>
                    <ci>q_us</ci>
                    <ci>q_C</ci>
                </apply>
            </apply>
        </math>
        <variable name="C" public_interface="out" units="m6_per_J"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>C</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
        </math>
        <variable name="Z" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>Z</ci>
                <apply>
                    <plus/>
                    <apply>
                        <times/>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">0.8</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">0.075</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                            <apply>
                                <divide/>
                                <cn cellml:units="dimensionless">1</cn>
                                <apply>
                                    <plus/>
                                    <cn cellml:units="dimensionless">1</cn>
                                    <apply>
                                        <times/>
                                        <apply>
                                            <power/>
                                            <cn cellml:units="dimensionless">10</cn>
                                            <apply>
                                                <minus/>
                                                <cn cellml:units="dimensionless">11</cn>
                                            </apply>
                                        </apply>
                                        <apply>
                                            <power/>
                                            <apply>
                                                <times/>
                                                <cn cellml:units="dimensionless">2</cn>
                                                <ci>r</ci>
                                                <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                            </apply>
                                            <cn cellml:units="dimensionless">12</cn>
                                        </apply>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <divide/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <plus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <apply>
                                    <power/>
                                    <cn cellml:units="dimensionless">10</cn>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">11</cn>
                                    </apply>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">12</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu_45" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu_45</ci>
                <apply>
                    <minus/>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6</cn>
                            <apply>
                                <exp/>
                                <apply>
                                    <times/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="per_m">0.085</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                        <cn cellml:units="dimensionless">3.2</cn>
                    </apply>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2.44</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <cn cellml:units="dimensionless">0.06</cn>
                                </apply>
                                <apply>
                                    <power/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="per_m">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="dimensionless">0.645</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="mu" public_interface="out" units="Js_per_m3"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>mu</ci>
                <apply>
                    <times/>
                    <ci>hem_dep_u_rel</ci>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
        </math>
        <variable name="hem_dep_u_rel" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>hem_dep_u_rel</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <times/>
                        <apply>
                            <divide/>
                            <apply>
                                <times/>
                                <apply>
                                    <minus/>
                                    <ci>mu_45</ci>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <power/>
                                        <apply>
                                            <minus/>
                                            <cn cellml:units="dimensionless">1</cn>
                                            <ci>H_mean</ci>
                                        </apply>
                                        <ci>Z</ci>
                                    </apply>
                                    <cn cellml:units="dimensionless">1</cn>
                                </apply>
                            </apply>
                            <apply>
                                <minus/>
                                <apply>
                                    <power/>
                                    <apply>
                                        <minus/>
                                        <cn cellml:units="dimensionless">1</cn>
                                        <ci>H_global_L</ci>
                                    </apply>
                                    <ci>Z</ci>
                                </apply>
                                <cn cellml:units="dimensionless">1</cn>
                            </apply>
                        </apply>
                        <apply>
                            <power/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <cn cellml:units="dimensionless">2</cn>
                                    <ci>r</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <minus/>
                                    <apply>
                                        <times/>
                                        <cn cellml:units="dimensionless">2</cn>
                                        <ci>r</ci>
                                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                    </apply>
                                    <cn cellml:units="metre">1.1</cn>
                                </apply>
                            </apply>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="R" public_interface="out" units="Js_per_m6"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>R</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu</ci>
                        <ci>l</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="v" public_interface="out" units="m3_per_s"/>
        <variable name="v_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
        <variable name="u" public_interface="out" units="J_per_m3"/>
        <variable name="u_mmHg" public_interface="out" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>u_mmHg</ci>
                <apply>
                    <divide/>
                    <ci>u</ci>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C</ci>
                        <ci>C</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C</ci>
                </apply>
                <apply>
                    <minus/>
                    <ci>v</ci>
                    <ci>v_d</ci>
                </apply>
            </apply>
        </math>
        <variable name="v_d" public_interface="out" units="m3_per_s"/>
        <variable name="v_d_mm3_s" public_interface="out" units="mm3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>v_d_mm3_s</ci>
                <apply>
                    <divide/>
                    <ci>v_d</ci>
                    <ci>one_mm3</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_d</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u</ci>
                        <ci>u_out</ci>
                    </apply>
                    <apply>
                        <divide/>
                        <ci>R</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                </apply>
            </apply>
        </math>
    </component>
</model>
