              <apply>
                <minus/>
                <apply>
                  <power/>
                  <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>H_global_L</ci>
                  </apply>
                  <ci>Z</ci>
                </apply>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
            </apply>
            <apply>
              <power/>
              <apply>
                <divide/>
                <apply>
                  <times/>
                  <cn cellml:units="dimensionless">2</cn>
                  <ci>r</ci>
                  <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                </apply>
                <apply>
                  <minus/>
                  <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r</ci>
                    <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                  </apply>
                  <cn cellml:units="metre">1.1</cn>
                </apply>
              </apply>
              <cn cellml:units="dimensionless">2</cn>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>R</ci>
        <apply>
          <divide/>
          <apply>
            <times/>
            <cn cellml:units="dimensionless">8</cn>
            <ci>mu</ci>
            <ci>l</ci>
          </apply>
          <apply>
            <times/>
            <pi/>
            <apply>
              <power/>
              <ci>r</ci>
              <cn cellml:units="dimensionless">4</cn>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>v_mm3_s</ci>
        <apply>
          <divide/>
          <ci>v</ci>
          <ci>one_mm3</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>v</ci>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>u</ci>
            <ci>u_out</ci>
          </apply>
          <ci>R</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>u_mmHg</ci>
        <apply>
          <divide/>
          <ci>u</ci>
          <cn cellml:units="J_per_m3">133.322</cn>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>u</ci>
        <apply>
          <plus/>
          <apply>
            <divide/>
            <ci>q_C</ci>
            <ci>C</ci>
          </apply>
          <ci>u_ext</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>q_C</ci>
        </apply>
        <apply>
          <minus/>
          <ci>v_in</ci>
          <ci>v</ci>
        </apply>
      </apply>
    </math>
  </component>
  <component name="V2_module">
    <variable name="t" units="second" interface="public"/>
    <variable name="H_global_L" units="dimensionless" interface="public"/>
    <variable name="H_global_R" units="dimensionless" interface="public"/>
    <variable name="H_L_out_RHS" units="dimensionless" interface="public"/>
    <variable name="H_R_out_LHS" units="dimensionless" interface="public"/>
    <variable name="gamma_mirror" units="dimensionless" interface="public"/>
    <variable name="tau_H_down" units="second" interface="public"/>
    <variable name="tau_H_mean" units="second" interface="public"/>
    <variable name="v_eps" units="m3_per_s" interface="public"/>
    <variable name="q_C_init" units="m3" interface="public"/>
    <variable name="l" units="metre" interface="public"/>
    <variable name="r" units="metre" interface="public"/>
    <variable name="mu_plasma" units="Js_per_m3" interface="public"/>
    <variable name="v_in" units="m3_per_s" interface="public"/>
    <variable name="u_ext" units="J_per_m3" interface="public"/>
    <variable name="u_out" units="J_per_m3" interface="public"/>
    <variable name="tau_link" units="second" interface="public"/>
    <variable name="v_scale" units="m3_per_s" interface="public"/>
    <variable name="one_mm3" units="m3" interface="public"/>
    <variable name="w_v" units="dimensionless" interface="public"/>
    <variable name="H_link_R" units="dimensionless" initial_value="H_global_L" interface="public"/>
    <variable name="H_link_L" units="dimensionless" initial_value="H_global_L" interface="public"/>
    <variable name="H_L_in" units="dimensionless" interface="public"/>
    <variable name="H_R_in" units="dimensionless" interface="public"/>
    <variable name="H_up" units="dimensionless" interface="public"/>
    <variable name="H_down" units="dimensionless" initial_value="H_global_L" interface="public"/>
    <variable name="H_down_target" units="dimensionless" interface="public"/>
    <variable name="s_v" units="dimensionless" interface="public"/>
    <variable name="H_L_out" units="dimensionless" interface="public"/>
    <variable name="H_R_out" units="dimensionless" interface="public"/>
    <variable name="RBC_volume" units="m3" initial_value="RBC_volume_init" interface="public"/>
    <variable name="RBC_volume_init" units="m3" interface="public"/>
    <variable name="v_pos" units="m3_per_s" interface="public"/>
    <variable name="v_neg" units="m3_per_s" interface="public"/>
    <variable name="H_mean" units="dimensionless" interface="public"/>
    <variable name="H_mass_L" units="dimensionless" interface="public"/>
    <variable name="H_mass_R" units="dimensionless" interface="public"/>
    <variable name="q_C" units="m3" initial_value="q_C_init" interface="public"/>
    <variable name="q" units="m3" interface="public"/>
    <variable name="q_us" units="m3" interface="public"/>
    <variable name="C" units="m6_per_J" interface="public"/>
    <variable name="Z" units="dimensionless" interface="public"/>
    <variable name="mu_45" units="dimensionless"/>
    <variable name="mu" units="Js_per_m3" interface="public"/>
    <variable name="hem_dep_u_rel" units="dimensionless"/>
    <variable name="R" units="Js_per_m6" interface="public"/>
    <variable name="v" units="m3_per_s" interface="public"/>
    <variable name="v_mm3_s" units="mm3_per_s" interface="public"/>
    <variable name="u" units="J_per_m3" interface="public"/>
    <variable name="u_mmHg" units="dimensionless" interface="public"/>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>w_v</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">0.5</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <cn cellml:units="dimensionless">1</cn>
              <pi/>
            </apply>
            <apply>
              <arctan/>
              <apply>
                <divide/>
                <ci>v</ci>
                <ci>v_scale</ci>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_link_R</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>H_L_out_RHS</ci>
            <ci>H_link_R</ci>
          </apply>
          <ci>tau_link</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_link_L</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>H_R_out_LHS</ci>
            <ci>H_link_L</ci>
          </apply>
          <ci>tau_link</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>H_L_in</ci>
        <ci>H_link_L</ci>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>H_R_in</ci>
        <ci>H_link_R</ci>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_up</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v</ci>
            <ci>H_L_in</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v</ci>
            </apply>
            <ci>H_R_in</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_down_target</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>s_v</ci>
            <apply>
              <plus/>
              <ci>H_mean</ci>
              <apply>
                <times/>
                <ci>gamma_mirror</ci>
                <apply>
                  <minus/>
                  <ci>H_mean</ci>
                  <ci>H_up</ci>
                </apply>
              </apply>
            </apply>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>s_v</ci>
            </apply>
            <ci>H_mean</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_down</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>H_down_target</ci>
            <ci>H_down</ci>
          </apply>
          <ci>tau_H_down</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>s_v</ci>
        <apply>
          <divide/>
          <apply>
            <abs/>
            <ci>v</ci>
          </apply>
          <apply>
            <plus/>
            <apply>
              <abs/>
              <ci>v</ci>
            </apply>
            <ci>v_eps</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_L_out</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v</ci>
            </apply>
            <ci>H_down</ci>
          </apply>
          <apply>
            <times/>
            <ci>w_v</ci>
            <ci>H_L_in</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>H_R_out</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v</ci>
            <ci>H_down</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v</ci>
            </apply>
            <ci>H_R_in</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>RBC_volume</ci>
        </apply>
        <apply>
          <minus/>
          <apply>
            <times/>
            <ci>v_in</ci>
            <ci>H_mass_L</ci>
          </apply>
          <apply>
            <times/>
            <ci>v</ci>
            <ci>H_mass_R</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>RBC_volume_init</ci>
        <apply>
          <times/>
          <ci>H_global_L</ci>
          <ci>q_us</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>v_pos</ci>
        <apply>
          <times/>
          <ci>w_v</ci>
          <ci>v</ci>
        </apply>
      </apply>
      <!-- inflow from left (v>0)-->
      <apply>
        <eq/>
        <ci>v_neg</ci>
        <apply>
          <times/>
          <apply>
            <minus/>
            <cn cellml:units="dimensionless">1</cn>
            <ci>w_v</ci>
          </apply>
          <apply>
            <minus/>
            <ci>v</ci>
          </apply>
        </apply>
      </apply>
      <!-- outflow to left (v<0)-->
      <!--var H_target: dimensionless {pub: out};-->
      <!--H_target = RBC_volume/q;-->
      <apply>
        <eq/>
        <ci>H_mean</ci>
        <apply>
          <divide/>
          <ci>RBC_volume</ci>
          <ci>q</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_mass_L</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v</ci>
            <ci>H_L_in</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v</ci>
            </apply>
            <ci>H_L_out</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>H_mass_R</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v</ci>
            <ci>H_R_out</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v</ci>
            </apply>
            <ci>H_R_in</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>q_us</ci>
        <apply>
          <times/>
          <pi/>
          <apply>
            <power/>
            <ci>r</ci>
            <cn cellml:units="dimensionless">2</cn>
          </apply>
          <ci>l</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>q</ci>
        <apply>
          <plus/>
          <ci>q_us</ci>
          <ci>q_C</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>C</ci>
        <apply>
          <divide/>
          <apply>
            <times/>
            <pi/>
            <apply>
              <power/>
              <cn type="e-notation" cellml:units="metre">8.5<sep/>-9</cn>
              <cn cellml:units="dimensionless">2</cn>
            </apply>
            <ci>l</ci>
          </apply>
          <cn cellml:units="J_per_m3">133.322</cn>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>Z</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <apply>
              <plus/>
              <cn cellml:units="dimensionless">0.8</cn>
              <apply>
                <exp/>
                <apply>
                  <times/>
                  <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">0.075</cn>
                  </apply>
                  <cn cellml:units="dimensionless">2</cn>
                  <ci>r</ci>
                  <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                </apply>
              </apply>
            </apply>
            <apply>
              <plus/>
              <apply>
                <minus/>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
                <divide/>
                <cn cellml:units="dimensionless">1</cn>
                <apply>
                  <plus/>
                  <cn cellml:units="dimensionless">1</cn>
                  <apply>
                    <times/>
                    <apply>
                      <power/>
                      <cn cellml:units="dimensionless">10</cn>
                      <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">11</cn>
                      </apply>
                    </apply>
                    <apply>
                      <power/>
                      <apply>
                        <times/>
                        <cn cellml:units="dimensionless">2</cn>
                        <ci>r</ci>
                        <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                      </apply>
                      <cn cellml:units="dimensionless">12</cn>
                    </apply>
                  </apply>
                </apply>
              </apply>
            </apply>
          </apply>
          <apply>
            <divide/>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <plus/>
              <cn cellml:units="dimensionless">1</cn>
              <apply>
                <times/>
                <apply>
                  <power/>
                  <cn cellml:units="dimensionless">10</cn>
                  <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">11</cn>
                  </apply>
                </apply>
                <apply>
                  <power/>
                  <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r</ci>
                    <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                  </apply>
                  <cn cellml:units="dimensionless">12</cn>
                </apply>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>mu_45</ci>
        <apply>
          <minus/>
          <apply>
            <plus/>
            <apply>
              <times/>
              <cn cellml:units="dimensionless">6</cn>
              <apply>
                <exp/>
                <apply>
                  <times/>
                  <apply>
                    <minus/>
                    <cn cellml:units="per_m">0.085</cn>
                  </apply>
                  <cn cellml:units="dimensionless">2</cn>
                  <ci>r</ci>
                  <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                </apply>
              </apply>
            </apply>
            <cn cellml:units="dimensionless">3.2</cn>
          </apply>
          <apply>
            <times/>
            <cn cellml:units="dimensionless">2.44</cn>
            <apply>
              <exp/>
              <apply>
                <times/>
                <apply>
                  <minus/>
                  <cn cellml:units="dimensionless">0.06</cn>
                </apply>
                <apply>
                  <power/>
                  <apply>
                    <times/>
                    <cn cellml:units="per_m">2</cn>
                    <ci>r</ci>
                    <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                  </apply>
                  <cn cellml:units="dimensionless">0.645</cn>
                </apply>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>mu</ci>
        <apply>
          <times/>
          <ci>hem_dep_u_rel</ci>
          <ci>mu_plasma</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>hem_dep_u_rel</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">1</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <apply>
                <times/>
                <apply>
                  <minus/>
                  <ci>mu_45</ci>
                  <cn cellml:units="dimensionless">1</cn>
                </apply>
                <apply>
                  <minus/>
                  <apply>
                    <power/>
                    <apply>
                      <minus/>
                      <cn cellml:units="dimensionless">1</cn>
                      <ci>H_mean</ci>
                    </apply>
                    <ci>Z</ci>
                  </apply>
                  <cn cellml:units="dimensionless">1</cn>
                </apply>
              </apply>
              <apply>
                <minus/>
                <apply>
                  <power/>
                  <apply>
                    <minus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <ci>H_global_L</ci>
                  </apply>
                  <ci>Z</ci>
                </apply>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
            </apply>
            <apply>
              <power/>
              <apply>
                <divide/>
                <apply>
                  <times/>
                  <cn cellml:units="dimensionless">2</cn>
                  <ci>r</ci>
                  <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                </apply>
                <apply>
                  <minus/>
                  <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r</ci>
                    <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                  </apply>
                  <cn cellml:units="metre">1.1</cn>
                </apply>
              </apply>
              <cn cellml:units="dimensionless">2</cn>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>R</ci>
        <apply>
          <divide/>
          <apply>
            <times/>
            <cn cellml:units="dimensionless">8</cn>
            <ci>mu</ci>
            <ci>l</ci>
          </apply>
          <apply>
            <times/>
            <pi/>
            <apply>
              <power/>
              <ci>r</ci>
              <cn cellml:units="dimensionless">4</cn>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>v_mm3_s</ci>
        <apply>
          <divide/>
          <ci>v</ci>
          <ci>one_mm3</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>v</ci>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>u</ci>
            <ci>u_out</ci>
          </apply>
          <ci>R</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>u_mmHg</ci>
        <apply>
          <divide/>
          <ci>u</ci>
          <cn cellml:units="J_per_m3">133.322</cn>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>u</ci>
        <apply>
          <plus/>
          <apply>
            <divide/>
            <ci>q_C</ci>
            <ci>C</ci>
          </apply>
          <ci>u_ext</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>q_C</ci>
        </apply>
        <apply>
          <minus/>
          <ci>v_in</ci>
          <ci>v</ci>
        </apply>
      </apply>
    </math>
  </component>
