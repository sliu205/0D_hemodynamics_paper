        <ci>H_daughter4</ci>
        <piecewise>
          <piece>
            <ci>H_mean</ci>
            <apply>
              <eq/>
              <ci>is_merge</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <ci>H_split4</ci>
            <apply>
              <eq/>
              <ci>is_split</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <ci>H_to4</ci>
            <true/>
          </piece>
        </piecewise>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_from1_target</ci>
        <piecewise>
          <piece>
            <ci>H_daughter1</ci>
            <apply>
              <eq/>
              <ci>bc1_is_out</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <ci>H_to1</ci>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>H_from2_target</ci>
        <piecewise>
          <piece>
            <ci>H_daughter2</ci>
            <apply>
              <eq/>
              <ci>bc2_is_out</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <ci>H_to2</ci>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>H_from3_target</ci>
        <piecewise>
          <piece>
            <ci>H_daughter3</ci>
            <apply>
              <eq/>
              <ci>bc3_is_out</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <ci>H_to3</ci>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>H_from4_target</ci>
        <piecewise>
          <piece>
            <ci>H_daughter4</ci>
            <apply>
              <eq/>
              <ci>bc4_is_out</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <ci>H_to4</ci>
            <true/>
          </piece>
        </piecewise>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_from1</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <times/>
            <ci>w_out1</ci>
            <apply>
              <minus/>
              <ci>H_from1_target</ci>
              <ci>H_from1</ci>
            </apply>
          </apply>
          <ci>tau_junc</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_from2</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <times/>
            <ci>w_out2</ci>
            <apply>
              <minus/>
              <ci>H_from2_target</ci>
              <ci>H_from2</ci>
            </apply>
          </apply>
          <ci>tau_junc</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_from3</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <times/>
            <ci>w_out3</ci>
            <apply>
              <minus/>
              <ci>H_from3_target</ci>
              <ci>H_from3</ci>
            </apply>
          </apply>
          <ci>tau_junc</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_from4</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <times/>
            <ci>w_out4</ci>
            <apply>
              <minus/>
              <ci>H_from4_target</ci>
              <ci>H_from4</ci>
            </apply>
          </apply>
          <ci>tau_junc</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>D1</ci>
        <apply>
          <times/>
          <cn cellml:units="dimensionless">2</cn>
          <ci>r_bc1</ci>
        </apply>
      </apply>
      <!--<&#45;&#45; port1 attached vessel diameter (example: parent VV side)-->
      <apply>
        <eq/>
        <ci>D2</ci>
        <apply>
          <times/>
          <cn cellml:units="dimensionless">2</cn>
          <ci>r_bc2</ci>
        </apply>
      </apply>
      <!--<&#45;&#45; port2 (if unused, still define)-->
      <apply>
        <eq/>
        <ci>D3</ci>
        <apply>
          <times/>
          <cn cellml:units="dimensionless">2</cn>
          <ci>r_bc3</ci>
        </apply>
      </apply>
      <!--<&#45;&#45; port3 daughter candidate-->
      <apply>
        <eq/>
        <ci>D4</ci>
        <apply>
          <times/>
          <cn cellml:units="dimensionless">2</cn>
          <ci>r_bc4</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>w_in1</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">0.5</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <cn cellml:units="dimensionless">1</cn>
              <pi/>
            </apply>
            <apply>
              <arctan/>
              <apply>
                <divide/>
                <ci>vj1</ci>
                <ci>v_scale</ci>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>w_in2</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">0.5</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <cn cellml:units="dimensionless">1</cn>
              <pi/>
            </apply>
            <apply>
              <arctan/>
              <apply>
                <divide/>
                <ci>vj2</ci>
                <ci>v_scale</ci>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>w_in3</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">0.5</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <cn cellml:units="dimensionless">1</cn>
              <pi/>
            </apply>
            <apply>
              <arctan/>
              <apply>
                <divide/>
                <ci>vj3</ci>
                <ci>v_scale</ci>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>w_in4</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">0.5</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <cn cellml:units="dimensionless">1</cn>
              <pi/>
            </apply>
            <apply>
              <arctan/>
              <apply>
                <divide/>
                <ci>vj4</ci>
                <ci>v_scale</ci>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>w_out1</ci>
        <apply>
          <minus/>
          <cn cellml:units="dimensionless">1</cn>
          <ci>w_in1</ci>
        </apply>
      </apply>
      <!-- ~1 if vj1<0-->
      <apply>
        <eq/>
        <ci>w_out2</ci>
        <apply>
          <minus/>
          <cn cellml:units="dimensionless">1</cn>
          <ci>w_in2</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>w_out3</ci>
        <apply>
          <minus/>
          <cn cellml:units="dimensionless">1</cn>
          <ci>w_in3</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>w_out4</ci>
        <apply>
          <minus/>
          <cn cellml:units="dimensionless">1</cn>
          <ci>w_in4</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>Qin1</ci>
        <apply>
          <times/>
          <ci>w_in1</ci>
          <ci>vj1</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>Qin2</ci>
        <apply>
          <times/>
          <ci>w_in2</ci>
          <ci>vj2</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>Qin3</ci>
        <apply>
          <times/>
          <ci>w_in3</ci>
          <ci>vj3</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>Qin4</ci>
        <apply>
          <times/>
          <ci>w_in4</ci>
          <ci>vj4</ci>
        </apply>
      </apply>
      <!--absolute (magnitude) of flow out of the junction-->
      <apply>
        <eq/>
        <ci>Qout1</ci>
        <apply>
          <times/>
          <ci>w_out1</ci>
          <apply>
            <minus/>
            <ci>vj1</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>Qout2</ci>
        <apply>
          <times/>
          <ci>w_out2</ci>
          <apply>
            <minus/>
            <ci>vj2</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>Qout3</ci>
        <apply>
          <times/>
          <ci>w_out3</ci>
          <apply>
            <minus/>
            <ci>vj3</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>Qout4</ci>
        <apply>
          <times/>
          <ci>w_out4</ci>
          <apply>
            <minus/>
            <ci>vj4</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>Qin_tot</ci>
        <apply>
          <plus/>
          <ci>Qin1</ci>
          <ci>Qin2</ci>
          <ci>Qin3</ci>
          <ci>Qin4</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>Qout_tot</ci>
        <apply>
          <plus/>
          <ci>Qout1</ci>
          <ci>Qout2</ci>
          <ci>Qout3</ci>
          <ci>Qout4</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>bc1_is_in</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qin1</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>bc2_is_in</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qin2</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>bc3_is_in</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qin3</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>bc4_is_in</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qin4</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>bc1_is_out</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qout1</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>bc2_is_out</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qout2</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>bc3_is_out</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qout3</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>bc4_is_out</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <gt/>
              <ci>Qout4</ci>
              <ci>v_threshold</ci>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>n_in</ci>
        <apply>
          <plus/>
          <ci>bc1_is_in</ci>
          <ci>bc2_is_in</ci>
          <ci>bc3_is_in</ci>
          <ci>bc4_is_in</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>n_out</ci>
        <apply>
          <plus/>
          <ci>bc1_is_out</ci>
          <ci>bc2_is_out</ci>
          <ci>bc3_is_out</ci>
          <ci>bc4_is_out</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>junction_type</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <eq/>
              <ci>n_in</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
            <apply>
              <geq/>
              <ci>n_in</ci>
              <cn cellml:units="dimensionless">2</cn>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>is_split</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <eq/>
              <ci>junction_type</ci>
              <cn cellml:units="dimensionless">1</cn>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>is_merge</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <eq/>
              <ci>junction_type</ci>
              <apply>
                <minus/>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>feed1</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <and/>
              <apply>
                <eq/>
                <ci>is_split</ci>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
                <geq/>
                <ci>Qin1</ci>
                <ci>Qin2</ci>
              </apply>
              <apply>
                <geq/>
                <ci>Qin1</ci>
                <ci>Qin3</ci>
              </apply>
              <apply>
                <geq/>
                <ci>Qin1</ci>
                <ci>Qin4</ci>
              </apply>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>feed2</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <and/>
              <apply>
                <eq/>
                <ci>is_split</ci>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
                <gt/>
                <ci>Qin2</ci>
                <ci>Qin1</ci>
              </apply>
              <apply>
                <geq/>
                <ci>Qin2</ci>
                <ci>Qin3</ci>
              </apply>
              <apply>
                <geq/>
                <ci>Qin2</ci>
                <ci>Qin4</ci>
              </apply>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>feed3</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <and/>
              <apply>
                <eq/>
                <ci>is_split</ci>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
                <gt/>
                <ci>Qin3</ci>
                <ci>Qin1</ci>
              </apply>
              <apply>
                <gt/>
                <ci>Qin3</ci>
                <ci>Qin2</ci>
              </apply>
              <apply>
                <geq/>
                <ci>Qin3</ci>
                <ci>Qin4</ci>
              </apply>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <apply>
        <eq/>
        <ci>feed4</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <and/>
              <apply>
                <eq/>
                <ci>is_split</ci>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
                <gt/>
                <ci>Qin4</ci>
                <ci>Qin1</ci>
              </apply>
              <apply>
                <gt/>
                <ci>Qin4</ci>
                <ci>Qin2</ci>
              </apply>
              <apply>
                <gt/>
                <ci>Qin4</ci>
                <ci>Qin3</ci>
              </apply>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>alpha1</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <and/>
              <apply>
                <eq/>
                <ci>is_split</ci>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
                <eq/>
                <ci>bc1_is_out</ci>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
                <geq/>
                <ci>Qout1</ci>
                <ci>Qout2</ci>
              </apply>
              <apply>
                <geq/>
                <ci>Qout1</ci>
                <ci>Qout3</ci>
              </apply>
              <apply>
                <geq/>
                <ci>Qout1</ci>
                <ci>Qout4</ci>
              </apply>
            </apply>
          </piece>
          <piece>
            <cn cellml:units="dimensionless">0</cn>
            <true/>
          </piece>
        </piecewise>
      </apply>
      <!-- alpha2 only if not alpha1 (tie-break) and port2 is a daughter and beats remaining-->
      <apply>
        <eq/>
        <ci>alpha2</ci>
        <piecewise>
          <piece>
            <cn cellml:units="dimensionless">1</cn>
            <apply>
              <and/>
              <apply>
                <eq/>
                <ci>is_split</ci>
                <cn cellml:units="dimensionless">1</cn>
              </apply>
              <apply>
