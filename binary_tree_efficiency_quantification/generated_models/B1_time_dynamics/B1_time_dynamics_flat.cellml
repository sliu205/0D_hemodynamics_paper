    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>mu_45</ci>
        <apply>
          <minus/>
          <apply>
            <plus/>
            <apply>
              <times/>
              <cn cellml:units="dimensionless">6</cn>
              <apply>
                <exp/>
                <apply>
                  <times/>
                  <apply>
                    <minus/>
                    <cn cellml:units="per_m">0.085</cn>
                  </apply>
                  <cn cellml:units="dimensionless">2</cn>
                  <ci>r</ci>
                  <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                </apply>
              </apply>
            </apply>
            <cn cellml:units="dimensionless">3.2</cn>
          </apply>
          <apply>
            <times/>
            <cn cellml:units="dimensionless">2.44</cn>
            <apply>
              <exp/>
              <apply>
                <times/>
                <apply>
                  <minus/>
                  <cn cellml:units="dimensionless">0.06</cn>
                </apply>
                <apply>
                  <power/>
                  <apply>
                    <times/>
                    <cn cellml:units="per_m">2</cn>
                    <ci>r</ci>
                    <cn type="e-notation" cellml:units="dimensionless">1<sep/>6</cn>
                  </apply>
                  <cn cellml:units="dimensionless">0.645</cn>
                </apply>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>mu</ci>
        <apply>
          <times/>
          <ci>hem_dep_u_rel</ci>
          <ci>mu_plasma</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>hem_dep_u_rel</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">1</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <apply>
                <times/>
                <apply>
                  <minus/>
