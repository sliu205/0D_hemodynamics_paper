    <unit exponent="-1" units="second"/>
  </units>
  <units name="L_per_s_per_kPa">
    <unit exponent="3" prefix="deci" units="metre"/>
    <unit exponent="-1" units="second"/>
    <unit exponent="-1" prefix="kilo" units="pascal"/>
  </units>
  <units name="kPa_per_L">
    <unit prefix="kilo" units="pascal"/>
    <unit exponent="-3" prefix="deci" units="metre"/>
  </units>
  <units name="L_per_kPa">
    <unit exponent="3" prefix="deci" units="metre"/>
    <unit exponent="-1" prefix="kilo" units="pascal"/>
  </units>
  <units name="kPa_s_per_L">
    <unit prefix="kilo" units="pascal"/>
    <unit units="second"/>
    <unit exponent="-3" prefix="deci" units="metre"/>
  </units>
  <component name="parameters">
    <variable name="l_inlet" units="metre" initial_value="0.0003" interface="public"/>
    <variable name="r_inlet" units="metre" initial_value="0.000006" interface="public"/>
    <variable name="H_R_out_LHS_inlet" units="dimensionless" initial_value="0.45" interface="public"/>
    <variable name="u_in_inlet" units="J_per_m3" initial_value="6666.1" interface="public"/>
    <variable name="l_VV_junc1" units="metre" initial_value="0.000001" interface="public"/>
    <variable name="r_VV_junc1" units="metre" initial_value="0.000006" interface="public"/>
    <variable name="vbc2_VV_junc1" units="m3_per_s" initial_value="0" interface="public"/>
    <variable name="H_to2_VV_junc1" units="dimensionless" initial_value="0" interface="public"/>
    <variable name="r_bc2_VV_junc1" units="metre" initial_value="0" interface="public"/>
    <variable name="C_conn2_VV_junc1" units="m6_per_J" initial_value="8.51E-22" interface="public"/>
    <variable name="R_constriction_final_PV1" units="Js_per_m6" initial_value="0" interface="public"/>
    <variable name="l_PV1" units="metre" initial_value="0.000015" interface="public"/>
    <variable name="r_PV1" units="metre" initial_value="0.000006" interface="public"/>
    <variable name="R_constriction_final_PV2" units="Js_per_m6" initial_value="0" interface="public"/>
    <variable name="l_PV2" units="metre" initial_value="0.000015" interface="public"/>
    <variable name="r_PV2" units="metre" initial_value="0.000006" interface="public"/>
    <variable name="l_V1" units="metre" initial_value="0.00025" interface="public"/>
    <variable name="r_V1" units="metre" initial_value="0.0000055" interface="public"/>
    <variable name="H_L_out_RHS_V1" units="dimensionless" initial_value="0.45" interface="public"/>
    <variable name="u_out_V1" units="J_per_m3" initial_value="6632.7695" interface="public"/>
    <variable name="l_V2" units="metre" initial_value="0.00025" interface="public"/>
    <variable name="r_V2" units="metre" initial_value="0.0000055" interface="public"/>
    <variable name="H_L_out_RHS_V2" units="dimensionless" initial_value="0.45" interface="public"/>
    <variable name="u_out_V2" units="J_per_m3" initial_value="6632.7695" interface="public"/>
  </component>
  <component name="parameters_global">
    <variable name="H_global_L" units="dimensionless" initial_value="0.45" interface="public"/>
    <variable name="H_global_R" units="dimensionless" initial_value="0.45" interface="public"/>
    <variable name="gamma_mirror" units="dimensionless" initial_value="0.1" interface="public"/>
    <variable name="tau_H_down" units="second" initial_value="0.001" interface="public"/>
    <variable name="tau_H_mean" units="second" initial_value="0.001" interface="public"/>
    <variable name="v_eps" units="m3_per_s" initial_value="1E-30" interface="public"/>
    <variable name="q_C_init" units="m3" initial_value="0" interface="public"/>
    <variable name="mu_plasma" units="Js_per_m3" initial_value="0.001" interface="public"/>
    <variable name="u_ext" units="J_per_m3" initial_value="133" interface="public"/>
    <variable name="tau_link" units="second" initial_value="0.001" interface="public"/>
    <variable name="v_scale" units="m3_per_s" initial_value="1E-50" interface="public"/>
    <variable name="one_mm3" units="m3" initial_value="0.000000001" interface="public"/>
    <variable name="div_0" units="dimensionless" initial_value="1E-25" interface="public"/>
    <variable name="div_0y" units="dimensionless" initial_value="0.00000001" interface="public"/>
    <variable name="tau_junc" units="second" initial_value="0.0001" interface="public"/>
    <variable name="v_threshold" units="m3_per_s" initial_value="1E-18" interface="public"/>
    <variable name="k" units="dimensionless" initial_value="1000" interface="public"/>
    <variable name="R" units="Js_per_m6" initial_value="1000000000000000" interface="public"/>
    <variable name="R_constriction_base" units="Js_per_m6" initial_value="0" interface="public"/>
    <variable name="tau_sig" units="second" initial_value="1" interface="public"/>
    <variable name="t0" units="second" initial_value="500" interface="public"/>
  </component>
  <component name="environment">
    <variable name="time" units="second" interface="public"/>
  </component>
  <component name="inlet_module">
    <variable name="t" units="second" interface="public"/>
    <variable name="H_global_L" units="dimensionless" interface="public"/>
    <variable name="H_global_R" units="dimensionless" interface="public"/>
    <variable name="H_L_out_RHS" units="dimensionless" interface="public"/>
    <variable name="H_R_out_LHS" units="dimensionless" interface="public"/>
    <variable name="gamma_mirror" units="dimensionless" interface="public"/>
    <variable name="tau_H_down" units="second" interface="public"/>
    <variable name="tau_H_mean" units="second" interface="public"/>
    <variable name="v_eps" units="m3_per_s" interface="public"/>
    <variable name="q_C_init" units="m3" interface="public"/>
    <variable name="l" units="metre" interface="public"/>
    <variable name="r" units="metre" interface="public"/>
    <variable name="mu_plasma" units="Js_per_m3" interface="public"/>
    <variable name="u_in" units="J_per_m3" interface="public"/>
    <variable name="u_ext" units="J_per_m3" interface="public"/>
    <variable name="u_out" units="J_per_m3" interface="public"/>
    <variable name="tau_link" units="second" interface="public"/>
    <variable name="v_scale" units="m3_per_s" interface="public"/>
    <variable name="one_mm3" units="m3" interface="public"/>
    <variable name="w_v" units="dimensionless" interface="public"/>
    <variable name="w_v_d" units="dimensionless" interface="public"/>
    <variable name="H_link_R" units="dimensionless" initial_value="H_global_L" interface="public"/>
    <variable name="H_link_L" units="dimensionless" initial_value="H_global_L" interface="public"/>
    <variable name="H_L_in" units="dimensionless" interface="public"/>
    <variable name="H_R_in" units="dimensionless" interface="public"/>
    <variable name="H_up" units="dimensionless" interface="public"/>
    <variable name="H_down" units="dimensionless" initial_value="H_global_L" interface="public"/>
    <variable name="H_down_target" units="dimensionless" interface="public"/>
    <variable name="s_v_d" units="dimensionless" interface="public"/>
    <variable name="H_L_out" units="dimensionless" interface="public"/>
    <variable name="H_R_out" units="dimensionless" interface="public"/>
    <variable name="RBC_volume" units="m3" initial_value="RBC_volume_init" interface="public"/>
    <variable name="RBC_volume_init" units="m3" interface="public"/>
    <variable name="v_pos" units="m3_per_s" interface="public"/>
    <variable name="v_neg" units="m3_per_s" interface="public"/>
    <variable name="v_d_pos" units="m3_per_s" interface="public"/>
    <variable name="v_d_neg" units="m3_per_s" interface="public"/>
    <variable name="H_mean" units="dimensionless" interface="public"/>
    <variable name="H_mass_L" units="dimensionless" interface="public"/>
    <variable name="H_mass_R" units="dimensionless" interface="public"/>
    <variable name="q_C" units="m3" initial_value="q_C_init" interface="public"/>
    <variable name="q" units="m3" interface="public"/>
    <variable name="q_us" units="m3" interface="public"/>
    <variable name="C" units="m6_per_J" interface="public"/>
    <variable name="Z" units="dimensionless" interface="public"/>
    <variable name="mu_45" units="dimensionless"/>
    <variable name="mu" units="Js_per_m3" interface="public"/>
    <variable name="hem_dep_u_rel" units="dimensionless"/>
    <variable name="R" units="Js_per_m6" interface="public"/>
    <variable name="v" units="m3_per_s" interface="public"/>
    <variable name="v_mm3_s" units="mm3_per_s" interface="public"/>
    <variable name="u" units="J_per_m3" interface="public"/>
    <variable name="u_mmHg" units="dimensionless" interface="public"/>
    <variable name="v_d" units="m3_per_s" interface="public"/>
    <variable name="v_d_mm3_s" units="mm3_per_s" interface="public"/>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>w_v</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">0.5</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <cn cellml:units="dimensionless">1</cn>
              <pi/>
            </apply>
            <apply>
              <arctan/>
              <apply>
                <divide/>
                <ci>v</ci>
                <ci>v_scale</ci>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>w_v_d</ci>
        <apply>
          <plus/>
          <cn cellml:units="dimensionless">0.5</cn>
          <apply>
            <times/>
            <apply>
              <divide/>
              <cn cellml:units="dimensionless">1</cn>
              <pi/>
            </apply>
            <apply>
              <arctan/>
              <apply>
                <divide/>
                <ci>v_d</ci>
                <ci>v_scale</ci>
              </apply>
            </apply>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_link_R</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>H_L_out_RHS</ci>
            <ci>H_link_R</ci>
          </apply>
          <ci>tau_link</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_link_L</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>H_R_out_LHS</ci>
            <ci>H_link_L</ci>
          </apply>
          <ci>tau_link</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>H_L_in</ci>
        <ci>H_link_L</ci>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>H_R_in</ci>
        <ci>H_link_R</ci>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_up</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v_d</ci>
            <ci>H_L_in</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v_d</ci>
            </apply>
            <ci>H_R_in</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_down_target</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>s_v_d</ci>
            <apply>
              <plus/>
              <ci>H_mean</ci>
              <apply>
                <times/>
                <ci>gamma_mirror</ci>
                <apply>
                  <minus/>
                  <ci>H_mean</ci>
                  <ci>H_up</ci>
                </apply>
              </apply>
            </apply>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>s_v_d</ci>
            </apply>
            <ci>H_mean</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>H_down</ci>
        </apply>
        <apply>
          <divide/>
          <apply>
            <minus/>
            <ci>H_down_target</ci>
            <ci>H_down</ci>
          </apply>
          <ci>tau_H_down</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>s_v_d</ci>
        <apply>
          <divide/>
          <apply>
            <abs/>
            <ci>v_d</ci>
          </apply>
          <apply>
            <plus/>
            <apply>
              <abs/>
              <ci>v_d</ci>
            </apply>
            <ci>v_eps</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_L_out</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v_d</ci>
            </apply>
            <ci>H_down</ci>
          </apply>
          <apply>
            <times/>
            <ci>w_v_d</ci>
            <ci>H_L_in</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>H_R_out</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v_d</ci>
            <ci>H_down</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v_d</ci>
            </apply>
            <ci>H_R_in</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <apply>
          <diff/>
          <bvar>
            <ci>t</ci>
          </bvar>
          <ci>RBC_volume</ci>
        </apply>
        <apply>
          <minus/>
          <apply>
            <times/>
            <ci>v</ci>
            <ci>H_mass_L</ci>
          </apply>
          <apply>
            <times/>
            <ci>v_d</ci>
            <ci>H_mass_R</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML">
      <apply>
        <eq/>
        <ci>RBC_volume_init</ci>
        <apply>
          <times/>
          <ci>H_global_L</ci>
          <ci>q_us</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>v_pos</ci>
        <apply>
          <times/>
          <ci>w_v</ci>
          <ci>v</ci>
        </apply>
      </apply>
      <!-- inflow from left (v>0)-->
      <apply>
        <eq/>
        <ci>v_neg</ci>
        <apply>
          <times/>
          <apply>
            <minus/>
            <cn cellml:units="dimensionless">1</cn>
            <ci>w_v</ci>
          </apply>
          <apply>
            <minus/>
            <ci>v</ci>
          </apply>
        </apply>
      </apply>
      <!-- outflow to left (v<0)-->
      <apply>
        <eq/>
        <ci>v_d_pos</ci>
        <apply>
          <times/>
          <ci>w_v_d</ci>
          <ci>v_d</ci>
        </apply>
      </apply>
      <!-- flow from left to right (v_d>0) =>outflow on right-->
      <apply>
        <eq/>
        <ci>v_d_neg</ci>
        <apply>
          <times/>
          <apply>
            <minus/>
            <cn cellml:units="dimensionless">1</cn>
            <ci>w_v_d</ci>
          </apply>
          <apply>
            <minus/>
            <ci>v_d</ci>
          </apply>
        </apply>
      </apply>
      <!-- inflow from right (v_d<0)-->
      <!--var H_target: dimensionless {pub: out};-->
      <!--H_target = RBC_volume/q;-->
      <apply>
        <eq/>
        <ci>H_mean</ci>
        <apply>
          <divide/>
          <ci>RBC_volume</ci>
          <ci>q</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>H_mass_L</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v</ci>
            <ci>H_L_in</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v</ci>
            </apply>
            <ci>H_L_out</ci>
          </apply>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>H_mass_R</ci>
        <apply>
          <plus/>
          <apply>
            <times/>
            <ci>w_v_d</ci>
            <ci>H_R_out</ci>
          </apply>
          <apply>
            <times/>
            <apply>
              <minus/>
              <cn cellml:units="dimensionless">1</cn>
              <ci>w_v_d</ci>
            </apply>
            <ci>H_R_in</ci>
          </apply>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>q_us</ci>
        <apply>
          <times/>
          <pi/>
          <apply>
            <power/>
            <ci>r</ci>
            <cn cellml:units="dimensionless">2</cn>
          </apply>
          <ci>l</ci>
        </apply>
      </apply>
      <apply>
        <eq/>
        <ci>q</ci>
        <apply>
          <plus/>
          <ci>q_us</ci>
          <ci>q_C</ci>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>C</ci>
        <apply>
          <divide/>
          <apply>
            <times/>
            <pi/>
            <apply>
              <power/>
              <cn type="e-notation" cellml:units="metre">8.5<sep/>-9</cn>
              <cn cellml:units="dimensionless">2</cn>
            </apply>
            <ci>l</ci>
          </apply>
          <cn cellml:units="J_per_m3">133.322</cn>
        </apply>
      </apply>
    </math>
    <math xmlns="http://www.w3.org/1998/Math/MathML" xmlns:cellml="http://www.cellml.org/cellml/2.0#">
      <apply>
        <eq/>
        <ci>Z</ci>
        <apply>
          <plus/>
          <apply>
