                    <apply>
                      <minus/>
                      <cn cellml:units="dimensionless">1</cn>
                      <ci>H_mean</ci>
                    </apply>
                    <ci>Z</ci>
                  </apply>
                  <cn cellml:units="dimensionless">1</cn>
