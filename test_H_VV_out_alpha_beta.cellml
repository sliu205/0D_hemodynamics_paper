<?xml version='1.0' encoding='UTF-8'?>
<model name="minimal_pries_test" xmlns="http://www.cellml.org/cellml/1.1#" xmlns:cellml="http://www.cellml.org/cellml/1.1#">
    <units name="Js_per_m3">
        <unit units="joule"/>
        <unit units="second"/>
        <unit exponent="-1" units="metre"/>
    </units>
    <!-- wrong, fix:-->
    <units name="Js_per_m3">
        <unit units="joule"/>
        <unit units="second"/>
        <unit exponent="-3" units="metre"/>
    </units>
    <units name="Js_per_m6">
        <unit units="joule"/>
        <unit units="second"/>
        <unit exponent="-6" units="metre"/>
    </units>
    <units name="J_per_m3">
        <unit units="joule"/>
        <unit exponent="-3" units="metre"/>
    </units>
    <units name="m3_per_s">
        <unit exponent="3" units="metre"/>
        <unit exponent="-1" units="second"/>
    </units>
    <units name="m3">
        <unit exponent="3" units="metre"/>
    </units>
    <units name="m6_per_J">
        <unit exponent="6" units="metre"/>
        <unit exponent="-1" units="joule"/>
    </units>
    <component name="test">
        <variable initial_value="0" name="t" units="second"/>
        <!-- -->
        <variable initial_value="6666" name="u_in" units="J_per_m3"/>
        <variable initial_value="6500" name="u_out3" units="J_per_m3"/>
        <variable initial_value="6500" name="u_out4" units="J_per_m3"/>
        <variable initial_value="133" name="u_ext" units="J_per_m3"/>
        <variable initial_value="0.001" name="mu_plasma" units="Js_per_m3"/>
        <variable initial_value="0.3" name="H_global_L" units="dimensionless"/>
        <variable initial_value="1e-25" name="div_0" units="dimensionless"/>
        <variable initial_value="1e-08" name="div_0y" units="dimensionless"/>
        <variable initial_value="100" name="k" units="dimensionless"/>
        <variable initial_value="0" name="q_C_init" units="m3"/>
        <!-- feeder vessel geometry-->
        <variable initial_value="0.0002" name="l_F" units="metre"/>
        <variable initial_value="8e-06" name="r_F" units="metre"/>
        <!-- daughter 1 (alpha)-->
        <variable initial_value="0.0001" name="l_A" units="metre"/>
        <variable initial_value="6e-06" name="r_A" units="metre"/>
        <!-- daughter 2 (beta)-->
        <variable initial_value="0.0001" name="l_B" units="metre"/>
        <variable initial_value="4e-06" name="r_B" units="metre"/>
        <!-- -->
        <variable name="H_mean_F" units="dimensionless"/>
        <variable initial_value="1.20637042637874e-14" name="RBC_F" units="m3"/>
        <!-- H_global_L * q_us_F-->
        <variable name="q_us_F" units="m3"/>
        <variable initial_value="2.22423817877303e-18" name="q_C_F" units="m3"/>
        <variable name="C_F" units="m6_per_J"/>
        <variable name="mu_F" units="Js_per_m3"/>
        <variable name="R_F" units="Js_per_m6"/>
        <variable name="u_junc" units="J_per_m3"/>
        <variable name="v_F" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us_F</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r_F</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l_F</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>C_F</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l_F</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_mean_F</ci>
                <apply>
                    <divide/>
                    <ci>RBC_F</ci>
                    <apply>
                        <plus/>
                        <ci>q_us_F</ci>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>mu_F</ci>
                <apply>
                    <times/>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2.5</cn>
                            <ci>H_mean_F</ci>
                        </apply>
                    </apply>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
            <!-- simple linear viscosity-->
            <apply>
                <eq/>
                <ci>R_F</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu_F</ci>
                        <ci>l_F</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r_F</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_junc</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C_F</ci>
                        <ci>C_F</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_F</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_in</ci>
                        <ci>u_junc</ci>
                    </apply>
                    <ci>R_F</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C_F</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <minus/>
                        <ci>v_F</ci>
                        <ci>v_A</ci>
                    </apply>
                    <ci>v_B</ci>
                </apply>
            </apply>
            <!-- flow balance at junction-->
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_F</ci>
                </apply>
                <apply>
                    <minus/>
                    <apply>
                        <times/>
                        <ci>v_F</ci>
                        <ci>H_global_L</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <times/>
                            <ci>v_A</ci>
                            <ci>H_VV_alpha</ci>
                        </apply>
                        <apply>
                            <times/>
                            <ci>v_B</ci>
                            <ci>H_VV_beta</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!-- -->
        <variable name="FQB_alpha" units="dimensionless"/>
        <variable name="FQE_alpha" units="dimensionless"/>
        <variable name="A_p" units="dimensionless"/>
        <variable name="B_p" units="dimensionless"/>
        <variable name="X_0" units="dimensionless"/>
        <variable name="y_raw" units="dimensionless"/>
        <variable name="y" units="dimensionless"/>
        <variable name="ph" units="dimensionless"/>
        <variable name="D_F_m" units="metre"/>
        <variable name="D_A_m" units="metre"/>
        <variable name="D_B_m" units="metre"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>D_F_m</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_F</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>D_A_m</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_A</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>D_B_m</ci>
                <apply>
                    <times/>
                    <cn cellml:units="dimensionless">2</cn>
                    <ci>r_B</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>FQB_alpha</ci>
                <apply>
                    <divide/>
                    <apply>
                        <plus/>
                        <ci>v_A</ci>
                        <ci>div_0</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <ci>v_A</ci>
                        <ci>v_B</ci>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2</cn>
                            <ci>div_0</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>A_p</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">6.96</cn>
                        </apply>
                        <apply>
                            <ln/>
                            <apply>
                                <divide/>
                                <apply>
                                    <times/>
                                    <ci>D_A_m</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                                <apply>
                                    <times/>
                                    <ci>D_B_m</ci>
                                    <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                    <apply>
                        <times/>
                        <ci>D_F_m</ci>
                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>B_p</ci>
                <apply>
                    <plus/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">6.98</cn>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>H_mean_F</ci>
                            </apply>
                        </apply>
                        <apply>
                            <times/>
                            <ci>D_F_m</ci>
                            <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>X_0</ci>
                <apply>
                    <divide/>
                    <cn cellml:units="dimensionless">0.4</cn>
                    <apply>
                        <times/>
                        <ci>D_F_m</ci>
                        <cn cellml:units="dimensionless" type="e-notation">1<sep/>6</cn>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>y_raw</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>FQB_alpha</ci>
                        <ci>X_0</ci>
                    </apply>
                    <apply>
                        <plus/>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <apply>
                                <times/>
                                <cn cellml:units="dimensionless">2</cn>
                                <ci>X_0</ci>
                            </apply>
                        </apply>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>y</ci>
                <apply>
                    <min/>
                    <apply>
                        <max/>
                        <ci>y_raw</ci>
                        <ci>div_0y</ci>
                    </apply>
                    <apply>
                        <minus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <ci>div_0y</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>ph</ci>
                <apply>
                    <ln/>
                    <apply>
                        <divide/>
                        <ci>y</ci>
                        <apply>
                            <minus/>
                            <cn cellml:units="dimensionless">1</cn>
                            <ci>y</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>FQE_alpha</ci>
                <apply>
                    <divide/>
                    <cn cellml:units="dimensionless">1</cn>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <exp/>
                            <apply>
                                <minus/>
                                <apply>
                                    <plus/>
                                    <ci>A_p</ci>
                                    <apply>
                                        <times/>
                                        <ci>B_p</ci>
                                        <ci>ph</ci>
                                    </apply>
                                </apply>
                            </apply>
                        </apply>
                    </apply>
                </apply>
            </apply>
        </math>
        <!-- -->
        <variable name="epsilon_a" units="dimensionless"/>
        <variable name="epsilon_b" units="dimensionless"/>
        <variable initial_value="0.31764780646222" name="H_VV_alpha" units="dimensionless"/>
        <variable initial_value="0.247320575924192" name="H_VV_beta" units="dimensionless"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>epsilon_a</ci>
                <apply>
                    <minus/>
                    <ci>H_VV_alpha</ci>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>H_mean_F</ci>
                            <ci>FQE_alpha</ci>
                        </apply>
                        <apply>
                            <plus/>
                            <ci>FQB_alpha</ci>
                            <ci>div_0</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>epsilon_b</ci>
                <apply>
                    <minus/>
                    <ci>H_VV_beta</ci>
                    <apply>
                        <divide/>
                        <apply>
                            <times/>
                            <ci>H_mean_F</ci>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>FQE_alpha</ci>
                            </apply>
                        </apply>
                        <apply>
                            <plus/>
                            <apply>
                                <minus/>
                                <cn cellml:units="dimensionless">1</cn>
                                <ci>FQB_alpha</ci>
                            </apply>
                            <ci>div_0</ci>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_VV_alpha</ci>
                </apply>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <ci>k</ci>
                    </apply>
                    <ci>epsilon_a</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>H_VV_beta</ci>
                </apply>
                <apply>
                    <times/>
                    <apply>
                        <minus/>
                        <ci>k</ci>
                    </apply>
                    <ci>epsilon_b</ci>
                </apply>
            </apply>
        </math>
        <!-- -->
        <variable name="H_mean_A" units="dimensionless"/>
        <variable initial_value="1.55041889080617e-12" name="RBC_A" units="m3"/>
        <variable name="q_us_A" units="m3"/>
        <variable initial_value="4.61828541780886e-12" name="q_C_A" units="m3"/>
        <variable name="C_A" units="m6_per_J"/>
        <variable name="mu_A" units="Js_per_m3"/>
        <variable name="R_A" units="Js_per_m6"/>
        <variable name="u_A" units="J_per_m3"/>
        <variable name="v_A" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us_A</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r_A</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l_A</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>C_A</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l_A</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_mean_A</ci>
                <apply>
                    <divide/>
                    <ci>RBC_A</ci>
                    <apply>
                        <plus/>
                        <ci>q_us_A</ci>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>mu_A</ci>
                <apply>
                    <times/>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2.5</cn>
                            <ci>H_mean_A</ci>
                        </apply>
                    </apply>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>R_A</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu_A</ci>
                        <ci>l_A</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r_A</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_A</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C_A</ci>
                        <ci>C_A</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_A</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_junc</ci>
                        <ci>u_out3</ci>
                    </apply>
                    <ci>R_A</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C_A</ci>
                </apply>
                <ci>v_A</ci>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_A</ci>
                </apply>
                <apply>
                    <times/>
                    <ci>v_A</ci>
                    <ci>H_VV_alpha</ci>
                </apply>
            </apply>
        </math>
        <!-- inlet H comes from junction, no outlet feedback-->
        <!-- -->
        <variable name="H_mean_B" units="dimensionless"/>
        <variable initial_value="4.05470386016626e-13" name="RBC_B" units="m3"/>
        <variable name="q_us_B" units="m3"/>
        <variable initial_value="1.47488896157488e-12" name="q_C_B" units="m3"/>
        <variable name="C_B" units="m6_per_J"/>
        <variable name="mu_B" units="Js_per_m3"/>
        <variable name="R_B" units="Js_per_m6"/>
        <variable name="u_B" units="J_per_m3"/>
        <variable name="v_B" units="m3_per_s"/>
        <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
                <eq/>
                <ci>q_us_B</ci>
                <apply>
                    <times/>
                    <pi/>
                    <apply>
                        <power/>
                        <ci>r_B</ci>
                        <cn cellml:units="dimensionless">2</cn>
                    </apply>
                    <ci>l_B</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>C_B</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <cn cellml:units="metre" type="e-notation">8.5<sep/>-9</cn>
                            <cn cellml:units="dimensionless">2</cn>
                        </apply>
                        <ci>l_B</ci>
                    </apply>
                    <cn cellml:units="J_per_m3">133.322</cn>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>H_mean_B</ci>
                <apply>
                    <divide/>
                    <ci>RBC_B</ci>
                    <apply>
                        <plus/>
                        <ci>q_us_B</ci>
                        <ci>div_0</ci>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>mu_B</ci>
                <apply>
                    <times/>
                    <apply>
                        <plus/>
                        <cn cellml:units="dimensionless">1</cn>
                        <apply>
                            <times/>
                            <cn cellml:units="dimensionless">2.5</cn>
                            <ci>H_mean_B</ci>
                        </apply>
                    </apply>
                    <ci>mu_plasma</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>R_B</ci>
                <apply>
                    <divide/>
                    <apply>
                        <times/>
                        <cn cellml:units="dimensionless">8</cn>
                        <ci>mu_B</ci>
                        <ci>l_B</ci>
                    </apply>
                    <apply>
                        <times/>
                        <pi/>
                        <apply>
                            <power/>
                            <ci>r_B</ci>
                            <cn cellml:units="dimensionless">4</cn>
                        </apply>
                    </apply>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>u_B</ci>
                <apply>
                    <plus/>
                    <apply>
                        <divide/>
                        <ci>q_C_B</ci>
                        <ci>C_B</ci>
                    </apply>
                    <ci>u_ext</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <ci>v_B</ci>
                <apply>
                    <divide/>
                    <apply>
                        <minus/>
                        <ci>u_junc</ci>
                        <ci>u_out4</ci>
                    </apply>
                    <ci>R_B</ci>
                </apply>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>q_C_B</ci>
                </apply>
                <ci>v_B</ci>
            </apply>
            <apply>
                <eq/>
                <apply>
                    <diff/>
                    <bvar>
                        <ci>t</ci>
                    </bvar>
                    <ci>RBC_B</ci>
                </apply>
                <apply>
                    <times/>
                    <ci>v_B</ci>
                    <ci>H_VV_beta</ci>
                </apply>
            </apply>
        </math>
    </component>
</model>
